---
/** /build — the agent builder, shown as a ghosted concept preview (the same
 *  honesty treatment as /registry). It is NOT live: assembling and installing
 *  an agent from this page is coming, and a build made here would break until
 *  the backend lands. Everything below the honesty banner is deliberately
 *  static and non-interactive. What IS real: every capsule shown is on GitHub
 *  today, and the manifest is a real Distro.toml. No em-dashes in copy. */
import Base from '../layouts/Base.astro';
import { AOS_RELEASE } from '../lib/release';

const platforms = [
  { name: 'Standalone daemon', sel: true },
  { name: 'Claude Code' },
  { name: 'Codex', soon: true },
  { name: 'Agent Hermes', soon: true },
  { name: 'OpenClaw', soon: true },
];

const archetypes = [
  { icon: '⌨', name: 'The Coder', desc: 'Ships code. Files, shell, the forge, and it remembers the project.', sel: true },
  { icon: '🔍', name: 'The Researcher', desc: 'Reads everything, remembers everything, cites its sources.' },
  { icon: '🎩', name: 'The Concierge', desc: 'Runs on your GPU, reachable from Telegram.' },
  { icon: '⚙', name: 'Bare Metal', desc: 'Just the loop and a way in. You add every capability yourself.' },
];

interface Opt { name: string; desc: string; key?: string; sel?: boolean }
interface Slot { icon: string; name: string; req: string; hint: string; opts: Opt[] }

const slots: Slot[] = [
  {
    icon: '◆', name: 'The brain', req: 'required', hint: 'Which model answers. Swap the vendor tomorrow without touching the rest.',
    opts: [
      { name: 'OpenAI-compatible', desc: 'LM Studio, Ollama, llama.cpp, on your GPU', sel: true },
      { name: 'OpenAI', desc: 'GPT models via your OpenAI key' },
    ],
  },
  {
    icon: '↻', name: 'The loop', req: 'required', hint: 'How it thinks: reason, act, observe, repeat.',
    opts: [{ name: 'ReAct', desc: 'The stateless reason-and-act coordinator', sel: true }],
  },
  {
    icon: '▤', name: 'The memory', req: 'optional', hint: 'What it learned yesterday, still there today.',
    opts: [
      { name: 'Cross-session memory', desc: 'Reads .aos/memory.md into the prompt', key: 'files', sel: true },
      { name: 'Session store', desc: 'Persistent, append-only conversation history', sel: true },
    ],
  },
  {
    icon: '⚒', name: 'The toolbelt', req: 'pick any', hint: 'Each tool is sealed. Each one costs a key.',
    opts: [
      { name: 'Files', desc: 'Read and write your project, behind the VFS airlock', key: 'files', sel: true },
      { name: 'Web', desc: 'Fetch and call APIs, behind the SSRF airlock', key: 'web', sel: true },
      { name: 'Shell', desc: 'Run commands, gated behind approval', key: 'commands', sel: true },
      { name: 'Self-manage', desc: 'Inspect and manage its own runtime', sel: true },
    ],
  },
  {
    icon: '✦', name: 'The skills', req: 'optional', hint: 'How-to knowledge any agent can pick up.',
    opts: [
      { name: 'Skills loader', desc: 'Loads SKILL.md packs from the workspace', key: 'files', sel: true },
      { name: 'Project rules', desc: 'Injects AGENTS.md into the prompt', key: 'files', sel: true },
      { name: 'The forge', desc: 'Teaches the agent to build its own capsules', sel: true },
    ],
  },
  {
    icon: '⌗', name: 'The frontends', req: 'need one', hint: 'How you reach it. Every frontend is an uplink to the same agent.',
    opts: [
      { name: 'Terminal', desc: 'The TUI, bridged over a Unix socket', sel: true },
      { name: 'Telegram', desc: 'A Telegram bot as a frontend' },
    ],
  },
];

// The assembled agent, as a stack of parts (base = the engine).
const stack = [
  { icon: '◆', label: 'brain', name: 'OpenAI-compatible' },
  { icon: '↻', label: 'loop', name: 'ReAct' },
  { icon: '▤', label: 'memory', name: 'Cross-session · Session' },
  { icon: '⚒', label: 'tools', name: 'Files · Web · Shell · Self-manage' },
  { icon: '✦', label: 'skills', name: 'Skills · Rules · Forge' },
  { icon: '⌗', label: 'frontend', name: 'Terminal' },
];
const keys = ['files', 'web', 'commands'];

const manifest = `# assembled at aos.unicity.ai — a starting point, edit freely
schema-version = 1

[distro]
id = "wanderer"
name = "wanderer"
pretty-name = "Wanderer 0.1.0"
version = "0.1.0"
description = "Assembled with the Unicity AOS builder"
astrid-version = "=0.9.4"

[[capsule]]
name = "astrid-capsule-openai-compat"
source = "@unicity-aos/capsule-openai-compat"
version = "0.2.0"
group = "llm"

[[capsule]]
name = "astrid-capsule-react"
source = "@unicity-aos/capsule-react"
version = "0.2.2"

[[capsule]]
name = "astrid-capsule-memory"
source = "@unicity-aos/capsule-memory"
version = "0.2.0"

[[capsule]]
name = "astrid-capsule-session"
source = "@unicity-aos/capsule-session"
version = "0.2.0"

[[capsule]]
name = "astrid-capsule-fs"
source = "@unicity-aos/capsule-fs"
version = "0.2.0"

[[capsule]]
name = "astrid-capsule-http"
source = "@unicity-aos/capsule-http"
version = "0.1.1"

[[capsule]]
name = "astrid-capsule-shell"
source = "@unicity-aos/capsule-shell"
version = "0.2.0"

[[capsule]]
name = "astrid-capsule-cli"
source = "@unicity-aos/capsule-cli"
version = "0.2.0"
role = "uplink"
`;

function highlight(src: string): string {
  return src
    .split('\n')
    .map((line) => {
      const e = line.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      if (e.trimStart().startsWith('#')) return `<span class="t-c">${e}</span>`;
      if (/^\[.*\]$/.test(e.trim())) return `<span class="t-k">${e}</span>`;
      return e.replace(/"([^"]*)"/g, '<span class="t-s">"$1"</span>');
    })
    .join('\n');
}

const commands = [
  {
    cmd: AOS_RELEASE.channels.stable.command,
    note: AOS_RELEASE.channels.stable.available
      ? `installs the signed AOS ${AOS_RELEASE.version} stable release`
      : `staged stable-channel contract; AOS ${AOS_RELEASE.version} is not published`,
  },
  { cmd: 'aos init', note: 'initializes the product-owned runtime home and Unicity CE composition' },
  { cmd: 'aos run', note: 'delegates the operator command to the bundled Astrid Runtime' },
];
---

<Base
  title="Build your agent — Unicity AOS (concept preview)"
  description="A preview of the Unicity AOS agent builder: name it, pick where it lives, start from an archetype, and mix and match real capsules into a real Distro.toml. Assembling and installing from this page is coming."
>
  <main class="build wrap">
    <header class="build-head">
      <p class="eyebrow">The builder · concept preview</p>
      <h1 class="build-title">Build your agent.<br /><span class="gradient-text">Part by part.</span></h1>
      <p class="prose dim build-lede">
        Every ability is a sealed capsule: the brain, the memory, the tools, the
        guards. Snap them together, then swap any part later without rebuilding
        the rest. Your agent can never take more than you gave it.
      </p>
      <p class="mono build-honesty">
        Concept preview. The builder is not live yet: assembling and installing an
        agent from this page is coming, and a build made here would break until
        the backend lands. What is real today, and shown honestly below: every
        capsule is in the <a href="https://github.com/unicity-aos/aos-ce">AOS CE workspace</a>,
        and the manifest follows the real <code>Distro.toml</code> shape. This
        preview does not assemble, sign, or install artifacts. Use the
        <a href="/developers/">developer guide</a> for the supported source workflow.
      </p>
    </header>

    <div class="build-ghost" aria-hidden="true">
      <!-- Step 1 -->
      <section class="bstep">
        <p class="bstep-label mono">Step 1 · name it, and pick where it lives</p>
        <div class="b1">
          <div class="bname">
            <span class="bcap mono">agent name</span>
            <div class="bname-field mono">wanderer</div>
          </div>
          <div class="bplatforms">
            {
              platforms.map((p) => (
                <span class={`bplat${p.sel ? ' sel' : ''}${p.soon ? ' off' : ''}`}>
                  {p.name}
                  {p.soon && <span class="soon-tag mono">soon</span>}
                </span>
              ))
            }
          </div>
        </div>
        <p class="bnote dim">
          Standalone runs as its own daemon: every frontend is an uplink to the
          same agent. On Claude Code, Claude is the brain and the frontend, so
          those two slots drop away.
        </p>
      </section>

      <!-- Step 2 -->
      <section class="bstep">
        <p class="bstep-label mono">Step 2 · start from an archetype</p>
        <div class="barchetypes">
          {
            archetypes.map((a) => (
              <div class={`barch card${a.sel ? ' sel' : ''}`}>
                <span class="barch-icon">{a.icon}</span>
                <span class="barch-name">{a.name}</span>
                <span class="barch-desc dim">{a.desc}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Step 3 -->
      <section class="bstep">
        <p class="bstep-label mono">Step 3 · the workbench</p>
        <div class="bbench">
          <div class="bslots">
            {
              slots.map((slot) => (
                <div class="bslot">
                  <div class="bslot-head">
                    <span class="bslot-icon">{slot.icon}</span>
                    <h3 class="bslot-name">{slot.name}</h3>
                    <span class="bslot-req mono">{slot.req}</span>
                  </div>
                  <div class="bopts">
                    {
                      slot.opts.map((o) => (
                        <span class={`bopt${o.sel ? ' sel' : ''}`}>
                          <span class="bopt-name">{o.name}</span>
                          <span class="bopt-desc dim">{o.desc}</span>
                          {o.key && <span class="bopt-key mono">key: {o.key}</span>}
                        </span>
                      ))
                    }
                  </div>
                </div>
              ))
            }
          </div>

          <aside class="bside">
            <div class="card bcard">
              <p class="bcap mono">your agent</p>
              <div class="agent-stack">
                {
                  stack.map((s) => (
                    <div class="stack-part">
                      <span class="stack-icon">{s.icon}</span>
                      <span class="stack-name">{s.name}</span>
                      <span class="stack-label mono">{s.label}</span>
                    </div>
                  ))
                }
                <div class="stack-core mono">the engine · dumb on purpose</div>
              </div>
              <p class="agent-name mono">wanderer</p>
              <p class="agent-count mono dim">8 capsules · files + web + commands</p>
            </div>

            <div class="card bcard">
              <p class="bcap mono">keys it will hold</p>
              <div class="keychips">
                {keys.map((k) => <span class="keychip mono on">✓ {k}</span>)}
                <span class="keychip mono never">passwords</span>
              </div>
              <p class="keys-note dim">
                Keys only ever get fewer down the chain. Passwords stay in the
                secret store and are never handed to the model.
              </p>
            </div>

            <div class="card bcard manifest-card">
              <div class="manifest-head">
                <span class="mono">Distro.toml</span>
                <span class="mono manifest-tag">real format</span>
              </div>
              <pre class="manifest mono" set:html={highlight(manifest)}></pre>
            </div>
          </aside>
        </div>
      </section>

      <!-- Step 4 -->
      <section class="bstep">
        <p class="bstep-label mono">Step 4 · take it home</p>
        <div class="card binstall">
          <h2 class="binstall-title">Run it as its own daemon</h2>
          <p class="dim binstall-note">
            The builder would hand you these. Save the Distro.toml, then point
            <code>aos init</code> at it: it installs every capsule, prompts for
            any keys, and writes a per-agent lockfile.
          </p>
          <ol class="cmd-list">
            {
              commands.map((c) => (
                <li class="cmd-row">
                  <code class="cmd mono">{c.cmd}</code>
                  <span class="cmd-note dim">{c.note}</span>
                </li>
              ))
            }
          </ol>
        </div>
      </section>
    </div>

    <p class="build-foot mono dim">
      Want to build the parts instead of the agent? The
      <a href="/playground/">playground</a> runs the real kernel and lets you
      write a capsule in this tab, today.
    </p>
  </main>
</Base>

<style>
  .build {
    padding-block: var(--s-7) var(--s-8);
    max-width: 76rem;
  }

  .build-head {
    margin-bottom: var(--s-5);
  }

  .build-title {
    font-size: var(--step-5);
    line-height: 1.02;
    margin-block: var(--s-2) var(--s-3);
  }

  .build-lede {
    font-size: var(--step-1);
    margin-bottom: var(--s-3);
  }

  .build-honesty {
    display: block;
    font-size: var(--step--1);
    line-height: 1.7;
    color: var(--audit);
    border: 1px dashed color-mix(in srgb, var(--audit) 45%, transparent);
    border-radius: 8px;
    padding: 0.8em 1.1em;
    max-width: 68ch;
  }

  .build-honesty code {
    color: var(--bus);
  }

  /* The ghost: visibly present, deliberately untouchable. Same treatment as
     the registry preview. */
  .build-ghost {
    opacity: 0.55;
    pointer-events: none;
    user-select: none;
    filter: saturate(0.75);
  }

  .bstep {
    margin-top: var(--s-6);
  }

  .bstep-label {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--capsule);
    margin-bottom: var(--s-3);
  }

  .bnote {
    font-size: var(--step--1);
    line-height: 1.6;
    max-width: 64ch;
    margin-top: var(--s-2);
    border-left: 2px solid color-mix(in srgb, var(--bus) 40%, transparent);
    padding-left: 0.9em;
  }

  /* step 1 */
  .b1 {
    display: grid;
    grid-template-columns: minmax(0, 18rem) minmax(0, 1fr);
    gap: var(--s-3);
    align-items: start;
  }

  @media (max-width: 780px) {
    .b1 { grid-template-columns: 1fr; }
  }

  .bcap {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--s-1);
  }

  .bname-field {
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    color: var(--text);
    font-size: var(--step-1);
    padding: 0.55em 0.8em;
  }

  .bplatforms {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    align-content: start;
  }

  .bplat {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    border: 1px solid var(--line);
    background: var(--bg-raised);
    border-radius: var(--radius);
    padding: 0.7em 1.1em;
    font-size: var(--step-0);
    color: var(--text);
  }

  .bplat.sel {
    border-color: var(--bus);
    background: color-mix(in srgb, var(--bus) 12%, var(--bg-raised));
    color: var(--bus);
  }

  .bplat.off {
    color: var(--text-faint);
  }

  .soon-tag {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  /* step 2 */
  .barchetypes {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--s-2);
  }

  @media (max-width: 860px) {
    .barchetypes { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 460px) {
    .barchetypes { grid-template-columns: 1fr; }
  }

  .barch {
    display: flex;
    flex-direction: column;
    gap: 0.35em;
    padding: var(--s-3);
  }

  .barch.sel {
    border-color: var(--capsule);
    background: var(--capsule-dim);
  }

  .barch-icon { font-size: 1.4rem; }
  .barch-name { font-size: var(--step-0); font-weight: 600; }
  .barch-desc { font-size: 0.76rem; line-height: 1.45; }

  /* step 3 */
  .bbench {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 21rem);
    gap: var(--s-3);
    align-items: start;
  }

  @media (max-width: 940px) {
    .bbench { grid-template-columns: 1fr; }
  }

  .bslots {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .bslot {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: var(--s-3);
    background: var(--bg-raised);
  }

  .bslot-head {
    display: flex;
    align-items: baseline;
    gap: 0.6em;
    margin-bottom: var(--s-2);
  }

  .bslot-icon { color: var(--capsule); font-size: 1.1rem; }
  .bslot-name { font-size: var(--step-0); font-weight: 600; }

  .bslot-req {
    margin-left: auto;
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .bopts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-1);
  }

  .bopt {
    flex: 1 1 13rem;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    border: 1px solid var(--line);
    background: var(--bg);
    border-radius: 8px;
    padding: 0.6em 0.8em;
  }

  .bopt.sel {
    border-color: var(--capsule);
    background: var(--capsule-dim);
  }

  .bopt-name { font-size: var(--step--1); font-weight: 600; }
  .bopt.sel .bopt-name::before {
    content: '● ';
    color: var(--capsule);
    font-size: 0.7em;
    vertical-align: 0.15em;
  }
  .bopt-desc { font-size: 0.72rem; line-height: 1.4; }
  .bopt-key { font-size: 0.64rem; color: var(--deny); }

  /* the side column */
  .bside {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    position: sticky;
    top: var(--s-5);
  }

  @media (max-width: 940px) {
    .bside { position: static; }
  }

  .bcard { padding: var(--s-3); }

  /* the assembled agent as a stack of parts */
  .agent-stack {
    display: flex;
    flex-direction: column;
    gap: 0.35em;
    margin: var(--s-2) 0;
  }

  .stack-part {
    display: flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.5em 0.7em;
    border: 1px solid color-mix(in srgb, var(--capsule) 35%, var(--line));
    border-radius: 8px;
    background: color-mix(in srgb, var(--capsule) 8%, var(--bg));
  }

  .stack-icon { color: var(--capsule); font-size: 0.9rem; flex: none; }

  .stack-name {
    flex: 1;
    font-size: 0.74rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stack-label {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    flex: none;
  }

  .stack-core {
    margin-top: 0.3em;
    padding: 0.6em 0.7em;
    border: 1px solid color-mix(in srgb, var(--kernel) 40%, var(--line));
    border-radius: 8px;
    background: var(--surface);
    color: var(--text-faint);
    font-size: 0.66rem;
    text-align: center;
  }

  .agent-name {
    text-align: center;
    font-size: var(--step-0);
    color: var(--text);
    margin-top: var(--s-1);
  }

  .agent-count {
    text-align: center;
    font-size: 0.68rem;
  }

  /* keys */
  .keychips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
    margin: var(--s-1) 0 var(--s-2);
  }

  .keychip {
    font-size: 0.7rem;
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.25em 0.6em;
    color: var(--text-faint);
  }

  .keychip.on {
    border-color: color-mix(in srgb, var(--deny) 45%, transparent);
    color: var(--deny);
  }

  .keychip.never {
    color: var(--text-faint);
    text-decoration: line-through;
  }

  .keys-note { font-size: 0.7rem; line-height: 1.5; }

  /* manifest */
  .manifest-card { padding: 0; overflow: hidden; }

  .manifest-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7em 0.9em;
    border-bottom: 1px solid var(--line);
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .manifest-tag {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .manifest {
    margin: 0;
    padding: 0.9em;
    font-size: 0.68rem;
    line-height: 1.55;
    color: var(--text-dim);
    overflow-x: auto;
    max-height: 24rem;
  }

  .manifest .t-k { color: var(--capsule); }
  .manifest .t-s { color: var(--bus); }
  .manifest .t-c { color: var(--text-faint); }

  /* step 4 */
  .binstall { padding: var(--s-4); }

  .binstall-title { font-size: var(--step-2); margin-bottom: var(--s-1); }

  .binstall-note {
    font-size: var(--step--1);
    line-height: 1.6;
    max-width: 64ch;
    margin-bottom: var(--s-3);
  }

  .binstall-note code { color: var(--bus); }

  .cmd-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .cmd-row {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
  }

  .cmd {
    display: block;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.7em 0.9em;
    font-size: 0.8rem;
    color: var(--bus);
    overflow-x: auto;
    white-space: nowrap;
  }

  .cmd-note { font-size: 0.72rem; }

  .build-foot {
    margin-top: var(--s-6);
    font-size: var(--step--1);
    line-height: 1.6;
    color: var(--text-faint);
  }

  .build-foot a { color: var(--bus); }
</style>
