---
import Base from '../layouts/Base.astro';

/** /siri — "Ask the Astrid Book" by voice, today, with no app.
 *
 *  Honesty contract for this page: the shortcut talks STRAIGHT to the
 *  provider the visitor picks. It is not Astrid answering — no kernel, no
 *  capability checks, no audit chain — and the page says so. The key lives
 *  in the visitor's own Shortcuts app, on their device, never with us.
 *
 *  The name is deliberate: "Ask the Astrid Book" (docs Q&A, which is what
 *  it truly is). "Ask Astrid" stays reserved for the native app, where the
 *  answer will come from a governed agent, in one breath.
 *
 *  ICLOUD_* below are Apple-signed share links, which can only be minted by
 *  sharing a shortcut from the Shortcuts app on a device. Until they're
 *  filled in, the page shows the build-it-yourself recipe (which it shows
 *  anyway — the recipe IS the transparency).
 */

const ICLOUD_CLAUDE = 'https://www.icloud.com/shortcuts/ed97d5e43cc641beb3c90ee6cea12fd4';
const ICLOUD_OPENAI = 'https://www.icloud.com/shortcuts/70a2f0c5c04642e8b5c519a1d5d8423e';

interface Step {
  action: string;
  detail: string;
}

// The recipes route through the provider's OWN app action (the Claude and
// ChatGPT apps both expose one to Shortcuts), so the shortcut holds no key
// and no secret of any kind — auth lives in the app the visitor already
// signed into. An API-key variant exists but is strictly worse for
// consumers; we don't teach it here.
const commonHead: Step[] = [
  {
    action: 'Ask for Input (Text)',
    detail: 'Prompt: "What do you want to ask the book?" — invoked by voice, Siri speaks this and listens.',
  },
  {
    action: 'Get Contents of URL',
    detail: 'GET https://unicity-astrid.github.io/llms.txt — the book map the model answers from.',
  },
];

const promptNote =
  'Compose the prompt in its text field: type "You answer questions about Astrid OS from its documentation map below. Answer in a few spoken-friendly sentences, no markdown." then insert the Contents of URL variable (step 2), then "Question:" and the Provided Input variable (step 1).';

const claudeSteps: Step[] = [
  ...commonHead,
  { action: 'Ask Claude (the Claude app’s action)', detail: promptNote },
  { action: 'Speak Text', detail: 'The result from step 3. Add Show Result too if you want it on screen.' },
];

const openaiSteps: Step[] = [
  ...commonHead,
  { action: 'Ask ChatGPT (the ChatGPT app’s action)', detail: promptNote },
  { action: 'Speak Text', detail: 'The result from step 3. Add Show Result too if you want it on screen.' },
];

const providers = [
  {
    id: 'claude',
    label: 'Claude',
    keyNote: 'the Claude app installed and signed in — no API key; it uses the account you already have',
    link: ICLOUD_CLAUDE,
    steps: claudeSteps,
  },
  {
    id: 'openai',
    label: 'ChatGPT',
    keyNote: 'the ChatGPT app installed and signed in — no API key; it uses the account you already have',
    link: ICLOUD_OPENAI,
    steps: openaiSteps,
  },
];
---

<Base
  title="Ask the Astrid Book with Siri"
  description="A Siri shortcut that answers questions about Astrid from its own documentation, by voice. Your key stays in your Shortcuts app; nothing goes through us."
>
  <main class="siri wrap">
    <header class="siri-head">
      <p class="eyebrow">Hey Siri</p>
      <h1>Ask the book.<br />Out loud.</h1>
      <p class="prose dim siri-lede">
        A Shortcut that turns Siri into a voice interface for the Astrid
        documentation: say <em>"Hey Siri, Ask the Astrid Book"</em>, ask your
        question, hear the answer. No app. Works on any iPhone. Add just
        one, whichever AI app is on your phone: both answer to the same
        phrase.
      </p>
      <p class="mono siri-honesty">
        Plain dealing: this shortcut routes through the AI app you already
        have, on the account you already signed into. It holds no key and
        no secret, and nothing goes through us. It is not Astrid answering —
        no kernel, no permission checks, no receipts. It's the book, read
        to you by a model you brought.
      </p>
    </header>

    <div class="siri-grid">
      {
        providers.map((p) => (
          <section class="card siri-card">
            <h2 class="siri-card-title">With {p.label}</h2>
            <p class="dim siri-card-note">You'll need {p.keyNote}. The shortcut asks for it once, when you add it.</p>
            {p.link ? (
              <a class="btn btn-primary" href={p.link}>
                Add to Siri →
              </a>
            ) : (
              <p class="mono siri-soon">One-tap add link coming. The recipe below builds it in about two minutes.</p>
            )}
            <details class="siri-recipe">
              <summary class="mono">The recipe · 4 actions, no key, no secrets</summary>
              <ol class="siri-steps">
                {p.steps.map((s) => (
                  <li>
                    <strong class="mono">{s.action}</strong>
                    <span class="dim">{s.detail}</span>
                  </li>
                ))}
              </ol>
              <p class="dim siri-recipe-foot">
                Name it exactly <strong>Ask the Astrid Book</strong> — that's the phrase Siri listens for.
              </p>
            </details>
          </section>
        ))
      }
    </div>

    <section class="siri-ladder prose">
      <h2>Where this is going</h2>
      <p class="dim">
        Today this is two beats: name the shortcut, then ask. When Astrid
        gains a native app, <em>"Hey Siri, ask Astrid how do capsules
        work"</em> becomes one breath, and the answer comes from your own
        agent — with its permissions, memory, and receipts — instead of a
        bare model. Same conversation, upgraded custodian. That's the plan,
        stated in advance so you can hold us to it.
      </p>
    </section>
  </main>
</Base>

<style>
  .siri {
    padding-block: calc(var(--s-6) + 2rem) var(--s-7);
    max-width: 60rem;
  }

  .siri-head h1 {
    font-size: var(--step-5);
    margin-block: var(--s-2) var(--s-3);
  }

  .siri-lede {
    max-width: 52ch;
    margin-bottom: var(--s-3);
  }

  .siri-honesty {
    display: inline-block;
    font-size: var(--step--1);
    line-height: 1.7;
    color: var(--audit);
    border: 1px dashed color-mix(in srgb, var(--audit) 45%, transparent);
    border-radius: 8px;
    padding: 0.5em 1em;
    max-width: 58ch;
  }

  .siri-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
    gap: var(--s-3);
    margin-block: var(--s-5);
  }

  .siri-card {
    padding: var(--s-3);
    display: grid;
    gap: var(--s-2);
    align-content: start;
  }

  .siri-card-title {
    font-size: var(--step-2);
  }

  .siri-card-note {
    font-size: var(--step--1);
  }

  .siri-soon {
    font-size: 0.72rem;
    color: var(--text-faint);
  }

  .siri-recipe summary {
    font-size: var(--step--1);
    color: var(--capsule);
    cursor: pointer;
  }

  .siri-steps {
    margin: var(--s-2) 0 0;
    padding-left: 1.2em;
    display: grid;
    gap: var(--s-2);
    font-size: var(--step--1);
    line-height: 1.6;
  }

  .siri-steps strong {
    display: block;
    color: var(--text);
    font-weight: 600;
  }

  .siri-recipe-foot {
    margin-top: var(--s-2);
    font-size: var(--step--1);
  }

  .siri-ladder h2 {
    font-size: var(--step-3);
    margin-bottom: var(--s-2);
  }

  .siri-ladder .dim {
    max-width: 58ch;
  }
</style>
