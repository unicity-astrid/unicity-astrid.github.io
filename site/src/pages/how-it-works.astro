---
/** /how-it-works — the 01 -> 10 cinematic. The eye stays on the home page;
 *  this tab is the scenes themselves, opening with a quiet title rather than
 *  the hero. Every animated element below is driven by the browser runtime. */
import Base from '../layouts/Base.astro';
import SceneThesis from '../components/SceneThesis.astro';
import SceneDumbKernel from '../components/SceneDumbKernel.astro';
import SceneCapsules from '../components/SceneCapsules.astro';
import SceneLayers from '../components/SceneLayers.astro';
import SceneKeys from '../components/SceneKeys.astro';
import SceneCapability from '../components/SceneCapability.astro';
import SceneHome from '../components/SceneHome.astro';
import SceneGrow from '../components/SceneGrow.astro';
import SceneAudiences from '../components/SceneAudiences.astro';
import SceneProof from '../components/SceneProof.astro';
import SceneBring from '../components/SceneBring.astro';
---

<Base
  title="How Unicity AOS works · from product to engine"
  description="The full tour from the Unicity AOS product and capsule distribution down to Astrid Runtime, the engine running in this browser."
>
  <main>
    <header class="tour-intro wrap">
      <p class="eyebrow">How it works</p>
      <h1 class="tour-title">The engine beneath AOS,<br /><span class="gradient-text">running in your tab</span>.</h1>
      <p class="prose dim tour-lede">
        This is not the full Unicity AOS distribution in a browser. Every animated element
        below is driven by Astrid Runtime, its engine, booted in this tab. Scroll and
        watch it route events, grant and deny capabilities, and grow a runtime-local
        audit chain.
      </p>
    </header>

    <SceneThesis />
    <SceneDumbKernel />
    <SceneCapsules />
    <SceneLayers />
    <SceneKeys />
    <SceneCapability />
    <SceneHome />
    <SceneGrow />
    <SceneAudiences />
    <SceneProof />
    <SceneBring />
  </main>
  <script>
    import { initScenes } from '../scripts/scenes';
    document.addEventListener('astro:page-load', () => {
      if (document.querySelector('[data-scene]')) initScenes();
    });
  </script>
</Base>

<style>
  .tour-intro {
    padding-block: calc(var(--s-7) + 2rem) var(--s-5);
  }

  .tour-title {
    font-size: var(--step-5);
    line-height: 1.04;
    margin-block: var(--s-2) var(--s-3);
    max-width: 18ch;
  }

  .tour-lede {
    font-size: var(--step-1);
  }
</style>
