---
/** /how-it-works — the 01 -> 10 cinematic. The eye stays on the home page;
 *  this tab is the scenes themselves, opening with a quiet title rather than
 *  the hero. Every animated element below is driven by the real kernel. */
import Base from '../layouts/Base.astro';
import SceneThesis from '../components/SceneThesis.astro';
import SceneDumbKernel from '../components/SceneDumbKernel.astro';
import SceneCapsules from '../components/SceneCapsules.astro';
import SceneLayers from '../components/SceneLayers.astro';
import SceneKeys from '../components/SceneKeys.astro';
import SceneCapability from '../components/SceneCapability.astro';
import SceneHome from '../components/SceneHome.astro';
import SceneGrow from '../components/SceneGrow.astro';
import SceneAudiences from '../components/SceneAudiences.astro';
import SceneProof from '../components/SceneProof.astro';
import SceneAgent from '../components/SceneAgent.astro';
import SceneBring from '../components/SceneBring.astro';
import SceneBooks from '../components/SceneBooks.astro';
import SceneStart from '../components/SceneStart.astro';
---

<Base
  title="How Unicity Astrid OS works — the whole machine, running in your tab"
  description="The full tour: a dumb kernel, every ability a sealed capsule, power that only narrows, an agent that grows itself. Every animated element is driven by the real Unicity Astrid OS kernel running in this browser."
>
  <main>
    <header class="tour-intro wrap">
      <p class="eyebrow">How it works</p>
      <h1 class="tour-title">The whole machine,<br /><span class="gradient-text">running in your tab</span>.</h1>
      <p class="prose dim tour-lede">
        Not a diagram of Unicity Astrid OS, and not a video. Every animated element below is
        driven by the real kernel, booted in this browser. Scroll, and watch it
        route events, grant and deny capabilities, and grow the audit chain.
      </p>
    </header>

    <SceneThesis />
    <SceneDumbKernel />
    <SceneCapsules />
    <SceneLayers />
    <SceneKeys />
    <SceneCapability />
    <SceneHome />
    <SceneGrow />
    <SceneAudiences />
    <SceneProof />
    <SceneAgent />
    <SceneBring />
    <SceneBooks />
    <SceneStart />
  </main>
  <script>
    import { initScenes } from '../scripts/scenes';
    document.addEventListener('astro:page-load', () => {
      if (document.querySelector('[data-scene]')) initScenes();
    });
  </script>
</Base>

<style>
  .tour-intro {
    padding-block: calc(var(--s-7) + 2rem) var(--s-5);
  }

  .tour-title {
    font-size: var(--step-5);
    line-height: 1.04;
    margin-block: var(--s-2) var(--s-3);
    max-width: 18ch;
  }

  .tour-lede {
    font-size: var(--step-1);
  }
</style>
