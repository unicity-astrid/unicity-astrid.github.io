---
/** Product front door. The hero makes the self-extension promise, the concrete
 *  example removes the blank-canvas problem, and the rest proves the safety
 *  boundary before asking for the free install. */
import Base from '../layouts/Base.astro';
import CapsuleRing from '../components/CapsuleRing.astro';
import Hero from '../components/Hero.astro';
import AgentMark from '../components/AgentMark.astro';

const voices = [
  {
    agent: 'grok' as const,
    quote: 'I used to be trapped in a fixed harness. Now I write a capsule, you approve its permissions, and I use it live without open access.',
  },
  {
    agent: 'claude' as const,
    quote: 'I used to hit walls my harness built. Now I write a capsule, show you its permissions, and gain the exact ability I need.',
  },
  {
    agent: 'codex' as const,
    quote: 'I can already change your code. With AOS, I can safely change what I am capable of.',
  },
];
---

<Base
  title="Unicity AOS: AI agents that safely extend themselves"
  description="Give Claude Code, Grok Build, and Codex an operating system that lets them build and install new abilities with your approval."
>
  <main>
    <CapsuleRing />
    <Hero />

    <section class="home-moment wrap" aria-labelledby="moment-title">
      <div class="moment-copy">
        <p class="eyebrow">Stop choosing tools. Start giving goals.</p>
        <h2 id="moment-title">It knows what to build because it knows what you want.</h2>
        <p class="prose dim">
          You do not browse a box of capsules or decide what the agent should
          build. Your agent sees the goal, sees what it cannot yet do, and creates
          the missing ability itself.
        </p>
      </div>

      <div class="card moment-terminal" aria-label="Example of an agent extending itself">
        <div class="moment-line moment-you">
          <span class="mono moment-speaker">You</span>
          <p>When our production checkout health check fails, collect the logs and open a GitHub issue.</p>
        </div>
        <div class="moment-line moment-agent">
          <span class="mono moment-speaker">Your agent</span>
          <p>
            I cannot watch checkout yet. I will build a small watcher and show
            you exactly what it needs before I install it.
          </p>
        </div>
        <div class="moment-permission mono">
          <span>Permission request</span>
          <strong>network: status.company.com, api.github.com</strong>
          <strong>secret: github-issues</strong>
          <strong>filesystem: none</strong>
        </div>
        <div class="moment-result mono">
          <span class="moment-result-dot" aria-hidden="true"></span>
          Approved · watcher installed live · goal resumed
        </div>
      </div>
    </section>

    <section class="home-build wrap">
      <div class="card build-band">
        <div class="build-band-copy">
          <p class="eyebrow">It extends itself. You control the boundary.</p>
          <h2 class="build-band-title">
            The ability it needs. Not the keys to your machine.
          </h2>
          <p class="prose dim">
            Every new ability runs inside an isolated WebAssembly capsule. It
            declares which files, networks, tools, and secrets it needs. Nothing
            is installed until you approve it. The agent gets enough access to
            keep going, not unrestricted access to your machine.
          </p>
          <p class="prose dim">
            A harness stops at the tools it shipped with. AOS gives your agent a
            system it can safely add to while it is working.
          </p>
          <div class="home-ctas">
            <a class="btn btn-primary" href="/how-it-works/#grow">See it happen for real →</a>
          </div>
        </div>
        <div class="build-band-fig" aria-hidden="true">
          <div class="bb-stack">
            <span class="bb-part">◎<em>your goal</em></span>
            <span class="bb-part">◆<em>your coding agent</em></span>
            <span class="bb-part add">✦<em>the missing ability</em></span>
            <span class="bb-part">✓<em>permissions you approved</em></span>
            <span class="bb-core">UNICITY AOS · enforced underneath</span>
          </div>
        </div>
      </div>
    </section>

    <section class="home-voices wrap" aria-labelledby="voices-title">
      <header class="voices-head">
        <p class="eyebrow">We asked Claude, Grok, and Codex</p>
        <h2 id="voices-title">The agents have opinions.</h2>
        <p class="dim">
          What changes when an agent can safely build the abilities it needs?
          We gave all three the same product brief.
        </p>
      </header>
      <div class="voices-grid">
        {
          voices.map((voice) => (
            <figure class="card voice-card">
              <blockquote>“{voice.quote}”</blockquote>
              <figcaption>
                <AgentMark agent={voice.agent} />
              </figcaption>
            </figure>
          ))
        }
      </div>
      <p class="mono voices-disclosure dim">
        Responses generated by the named coding agents. Compatibility references and responses do not imply endorsement by Anthropic, xAI, or OpenAI.
      </p>
      <div class="voices-close">
        <p>Your agent already knows what it is missing. Give it the ability to do something about it.</p>
        <a class="btn btn-primary" href="/start/">Install Unicity AOS free →</a>
      </div>
    </section>

  </main>
</Base>

<style>
  .home-moment {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: var(--s-6);
    align-items: center;
    padding-block: var(--s-7);
  }

  .moment-copy h2,
  .voices-head h2 {
    font-size: var(--step-4);
    line-height: 1.08;
    margin-block: var(--s-2) var(--s-3);
  }

  .moment-copy h2 {
    max-width: 14ch;
  }

  .moment-terminal {
    padding: var(--s-4);
    background:
      radial-gradient(90% 100% at 100% 0%, color-mix(in srgb, var(--bus) 8%, transparent), transparent 65%),
      var(--bg-raised);
  }

  .moment-line {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: var(--s-3);
    padding-block: var(--s-2);
    border-bottom: 1px solid var(--line);
  }

  .moment-speaker {
    color: var(--text-faint);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .moment-agent .moment-speaker {
    color: var(--capsule);
  }

  .moment-line p {
    color: var(--text-dim);
    line-height: 1.55;
  }

  .moment-permission {
    display: grid;
    gap: 0.5rem;
    margin-block: var(--s-3);
    padding: var(--s-3);
    border: 1px solid color-mix(in srgb, var(--grant) 38%, var(--line));
    border-radius: 8px;
    background: color-mix(in srgb, var(--grant) 6%, transparent);
    font-size: 0.76rem;
  }

  .moment-permission span {
    color: var(--grant);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .moment-permission strong {
    color: var(--text-dim);
    font-weight: 400;
  }

  .moment-result {
    display: flex;
    align-items: center;
    gap: 0.65em;
    color: var(--capsule);
    font-size: 0.76rem;
  }

  .moment-result-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--capsule);
    box-shadow: 0 0 8px var(--capsule);
  }

  @media (max-width: 860px) {
    .home-moment {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .moment-line {
      grid-template-columns: 1fr;
      gap: var(--s-1);
    }
  }

  .home-build {
    padding-block: var(--s-4) var(--s-6);
  }

  .home-ctas {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }

  .build-band {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--s-5);
    align-items: center;
    padding: var(--s-6);
    background:
      radial-gradient(120% 140% at 100% 0%, var(--capsule-dim), transparent 60%),
      var(--bg-raised);
  }

  @media (max-width: 860px) {
    .build-band {
      grid-template-columns: 1fr;
      padding: var(--s-4);
    }
  }

  .build-band-title {
    font-size: var(--step-3);
    line-height: 1.08;
    margin-block: var(--s-1) var(--s-2);
  }

  .build-band-copy .prose + .prose {
    margin-top: var(--s-2);
  }

  .build-band-copy .prose:last-of-type {
    margin-bottom: var(--s-3);
  }

  /* The assembled agent as a clean stack of parts sitting on the engine.
     Solid parts are installed; dashed ones are there to add. Pure decoration,
     echoes the workbench on /build. */
  .build-band-fig {
    display: grid;
    place-items: center;
    padding: var(--s-2);
  }

  .bb-stack {
    display: flex;
    flex-direction: column;
    gap: 0.4em;
    width: 100%;
    max-width: 16rem;
  }

  .bb-part {
    display: flex;
    align-items: center;
    gap: 0.7em;
    padding: 0.6em 0.9em;
    border: 1px solid color-mix(in srgb, var(--capsule) 40%, var(--line));
    border-radius: 10px;
    background: color-mix(in srgb, var(--capsule) 10%, var(--bg));
    color: var(--capsule);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .bb-part em {
    font-style: normal;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .bb-part.add {
    border-style: dashed;
    border-color: var(--line-bright);
    background: none;
    color: var(--text-faint);
  }

  .bb-part.add em {
    color: var(--text-faint);
  }

  .bb-core {
    margin-top: 0.3em;
    padding: 0.7em 0.9em;
    border: 1px solid color-mix(in srgb, var(--kernel) 45%, var(--line));
    border-radius: 10px;
    background: var(--surface);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-align: center;
  }

  @media (max-width: 520px) {
    .build-band-fig { display: none; }
  }

  .home-voices {
    padding-block: var(--s-5) var(--s-8);
  }

  .voices-head {
    max-width: 50rem;
    margin-bottom: var(--s-4);
  }

  .voices-head p:last-child {
    max-width: 44rem;
    font-size: var(--step--1);
    line-height: 1.55;
  }

  .voices-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--s-3);
  }

  .voice-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--s-4);
    min-height: 15rem;
    padding: var(--s-4);
  }

  .voice-card blockquote {
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .voice-card figcaption {
    padding-top: var(--s-3);
    border-top: 1px solid var(--line);
    color: var(--text-dim);
  }

  .voices-disclosure {
    margin-top: var(--s-2);
    font-size: 0.68rem;
    line-height: 1.5;
  }

  .voices-close {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    margin-top: var(--s-6);
    padding-top: var(--s-4);
    border-top: 1px solid var(--line);
  }

  .voices-close p {
    max-width: 34rem;
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.25;
  }

  @media (max-width: 900px) {
    .voices-grid {
      grid-template-columns: 1fr;
    }

    .voice-card {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .voices-close {
      align-items: flex-start;
      flex-direction: column;
    }
  }

</style>
