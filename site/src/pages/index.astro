---
/** Home. The eye and the hero live here, on the front door: the tall hero
 *  condenses the real-kernel eye into the rail as you scroll, then the page
 *  explains the shape of the OS and points you at the builder. The 01 -> 10
 *  cinematic moved to /how-it-works; the eye did NOT go with it. */
import Base from '../layouts/Base.astro';
import CapsuleRing from '../components/CapsuleRing.astro';
import Hero from '../components/Hero.astro';

const shape = [
  {
    tone: 'kernel',
    k: '01',
    title: 'One small, dumb kernel',
    body: 'It routes events, enforces capabilities, and runs the sandbox. No business logic, no opinions. Replacing what your agent can do never means forking the OS.',
  },
  {
    tone: 'capsule',
    k: '02',
    title: 'Everything else is a capsule',
    body: 'The model, the loop, the memory, the tools, the skills, the frontends. Each one is sealed WebAssembly with its permissions declared up front. Swap any part, keep the machine.',
    href: '/registry/',
    hrefLabel: 'Browse the registry',
  },
  {
    tone: 'grant',
    k: '03',
    title: 'Power that only narrows',
    body: 'Capabilities are signed tokens, not prompt instructions. A capsule can only hand its helpers less than it holds, never more. Every grant and denial lands on an audit chain you can read.',
    href: '/how-it-works/',
    hrefLabel: 'See it proven live',
  },
];
---

<Base
  title="Astrid — a modular operating system for AI agents"
  description="Every ability is a sealed capsule: the model, the memory, the tools, the guards. Snap them together into an agent, swap any part later, and it can never take more than you gave. Astrid runs underneath the agent you already use. This page runs the real kernel in your tab."
>
  <main>
    <CapsuleRing />
    <Hero />

    <section class="home-shape wrap" aria-label="What Astrid is">
      <div class="shape-grid">
        {
          shape.map((s) => (
            <article class={`card shape-card tone-${s.tone}`}>
              <p class="mono shape-k">{s.k}</p>
              <h2 class="shape-title">{s.title}</h2>
              <p class="shape-body dim">{s.body}</p>
              {s.href && (
                <a class="mono shape-link" href={s.href}>
                  {s.hrefLabel} →
                </a>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="home-build wrap">
      <div class="card build-band">
        <div class="build-band-copy">
          <p class="eyebrow">Assemble it like a loadout</p>
          <h2 class="build-band-title">
            Build your agent from parts. Swap any of them later.
          </h2>
          <p class="prose dim">
            Pick where it lives, start from an archetype, then mix and match
            capsules from the registry. Watch its manifest and its keys assemble
            as you go. The builder is a preview today; the capsules it is made of
            are real and on GitHub now.
          </p>
          <div class="home-ctas">
            <a class="btn btn-primary" href="/build/">See the builder →</a>
            <a class="btn" href="/registry/">Browse the registry</a>
          </div>
        </div>
        <div class="build-band-fig" aria-hidden="true">
          <div class="bb-stack">
            <span class="bb-part">◆<em>brain</em></span>
            <span class="bb-part">↻<em>loop</em></span>
            <span class="bb-part">▤<em>memory</em></span>
            <span class="bb-part add">⚒<em>tools</em></span>
            <span class="bb-part add">✦<em>skills</em></span>
            <span class="bb-core">the engine · dumb on purpose</span>
          </div>
        </div>
      </div>
    </section>

    <section class="home-next wrap">
      <a class="card next-card" href="/how-it-works/">
        <p class="mono next-k">The tour</p>
        <h3 class="next-title">Watch the whole machine run</h3>
        <p class="dim next-body">
          The kernel, the capsules, the capability gate, the audit chain. Every
          element on that page is driven by the real kernel in your tab.
        </p>
        <span class="mono next-go">How it works →</span>
      </a>
      <a class="card next-card" href="/book/">
        <p class="mono next-k">The book</p>
        <h3 class="next-title">Read it end to end</h3>
        <p class="dim next-body">
          The canonical reference: kernel, capsules, the host ABI, the bus, and
          the security model. It ships with the OS.
        </p>
        <span class="mono next-go">Open the book →</span>
      </a>
      <a class="card next-card" href="/start/">
        <p class="mono next-k">Get it</p>
        <h3 class="next-title">Install Astrid</h3>
        <p class="dim next-body">
          One command from GitHub Releases. Plugins for Claude, Grok, and Codex
          install only when those hosts are on the machine.
        </p>
        <span class="mono next-go">Install →</span>
      </a>
    </section>
  </main>
</Base>

<style>
  /* The shape strip: three cards that give the OS substance without the full
     cinematic. Each tone borrows one accent from the machine palette. */
  .home-shape {
    padding-block: var(--s-6) var(--s-5);
  }

  .shape-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--s-3);
  }

  @media (max-width: 860px) {
    .shape-grid { grid-template-columns: 1fr; }
  }

  .shape-card {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    padding: var(--s-4);
    border-top: 2px solid var(--line);
  }

  .tone-kernel { border-top-color: color-mix(in srgb, var(--kernel) 60%, transparent); }
  .tone-capsule { border-top-color: color-mix(in srgb, var(--capsule) 60%, transparent); }
  .tone-grant { border-top-color: color-mix(in srgb, var(--grant) 60%, transparent); }

  .shape-k {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--text-faint);
  }

  .tone-kernel .shape-k { color: var(--kernel); }
  .tone-capsule .shape-k { color: var(--capsule); }
  .tone-grant .shape-k { color: var(--grant); }

  .shape-title {
    font-size: var(--step-2);
    line-height: 1.1;
  }

  .shape-body {
    font-size: var(--step-0);
    line-height: 1.55;
    flex: 1;
  }

  .shape-link {
    font-size: var(--step--1);
    color: var(--bus);
    width: fit-content;
  }

  /* The build band: the Mr-Potato-Head invitation, made obvious. */
  .home-build {
    padding-block: var(--s-4);
  }

  .home-ctas {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }

  .build-band {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--s-5);
    align-items: center;
    padding: var(--s-6);
    background:
      radial-gradient(120% 140% at 100% 0%, var(--capsule-dim), transparent 60%),
      var(--bg-raised);
  }

  @media (max-width: 860px) {
    .build-band {
      grid-template-columns: 1fr;
      padding: var(--s-4);
    }
  }

  .build-band-title {
    font-size: var(--step-3);
    line-height: 1.08;
    margin-block: var(--s-1) var(--s-2);
  }

  .build-band-copy .prose { margin-bottom: var(--s-3); }

  /* The assembled agent as a clean stack of parts sitting on the engine.
     Solid parts are installed; dashed ones are there to add. Pure decoration,
     echoes the workbench on /build. */
  .build-band-fig {
    display: grid;
    place-items: center;
    padding: var(--s-2);
  }

  .bb-stack {
    display: flex;
    flex-direction: column;
    gap: 0.4em;
    width: 100%;
    max-width: 16rem;
  }

  .bb-part {
    display: flex;
    align-items: center;
    gap: 0.7em;
    padding: 0.6em 0.9em;
    border: 1px solid color-mix(in srgb, var(--capsule) 40%, var(--line));
    border-radius: 10px;
    background: color-mix(in srgb, var(--capsule) 10%, var(--bg));
    color: var(--capsule);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .bb-part em {
    font-style: normal;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .bb-part.add {
    border-style: dashed;
    border-color: var(--line-bright);
    background: none;
    color: var(--text-faint);
  }

  .bb-part.add em {
    color: var(--text-faint);
  }

  .bb-core {
    margin-top: 0.3em;
    padding: 0.7em 0.9em;
    border: 1px solid color-mix(in srgb, var(--kernel) 45%, var(--line));
    border-radius: 10px;
    background: var(--surface);
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-align: center;
  }

  @media (max-width: 520px) {
    .build-band-fig { display: none; }
  }

  /* Next steps: three plain doors out. */
  .home-next {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--s-3);
    padding-block: var(--s-5) var(--s-8);
  }

  @media (max-width: 860px) {
    .home-next { grid-template-columns: 1fr; }
  }

  .next-card {
    display: flex;
    flex-direction: column;
    gap: var(--s-1);
    padding: var(--s-4);
    color: var(--text);
  }

  .next-card:hover {
    text-decoration: none;
    border-color: var(--line-bright);
  }

  .next-k {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .next-title {
    font-size: var(--step-1);
    line-height: 1.1;
  }

  .next-body {
    font-size: var(--step--1);
    line-height: 1.55;
    flex: 1;
  }

  .next-body code {
    color: var(--bus);
    font-size: 0.9em;
  }

  .next-go {
    font-size: var(--step--1);
    color: var(--bus);
    margin-top: var(--s-1);
  }
</style>
