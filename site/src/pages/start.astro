---
import Base from '../layouts/Base.astro';
import { AOS_RELEASE } from '../lib/release';

const methods = [
  {
    id: 'stable',
    label: AOS_RELEASE.channels.stable.label,
    cmd: AOS_RELEASE.channels.stable.command,
    available: AOS_RELEASE.channels.stable.available,
    note: 'Installs the approved signed AOS release. Re-run the same command to self-heal or upgrade.',
  },
  {
    id: 'homebrew',
    label: 'Homebrew',
    cmd: AOS_RELEASE.homebrew.command,
    available: AOS_RELEASE.homebrew.available,
    note: 'Installs the signed AOS release and its pinned runtime bundle.',
  },
] as const satisfies ReadonlyArray<{
  id: string;
  label: string;
  cmd: string;
  available: boolean;
  note: string;
}>;

const liveMethods = methods.filter((method) => method.available);
const defaultMethod = liveMethods.find((method) => method.id === AOS_RELEASE.defaultChannel)?.id
  ?? liveMethods[0]?.id;
---

<Base
  title="Install Unicity AOS"
  description="Install Unicity AOS and connect supported coding hosts."
>
  <main class="start wrap">
    <header class="start-hero">
      <p class="eyebrow">Install</p>
      <h1>Unicity AOS</h1>
      <p class="prose dim start-lede">
        Install the signed stable release with one command. Run it again at any
        time to self-heal or upgrade.
      </p>

      <section
        class="card start-install"
        id="install"
        data-method={defaultMethod}
        aria-label="Install command"
      >
        {
          liveMethods.map((m) => (
            <span id={m.id} class="start-anchor" aria-hidden="true" />
          ))
        }
        <div class="start-tabs" role="tablist" aria-label="Install method">
          {
            liveMethods.map((m) => (
              <button
                class="mono start-tab"
                role="tab"
                type="button"
                id={`tab-${m.id}`}
                data-tab={m.id}
                aria-selected={m.id === defaultMethod ? 'true' : 'false'}
                aria-controls={`panel-${m.id}`}
                tabindex={m.id === defaultMethod ? 0 : -1}
              >
                {m.label}
              </button>
            ))
          }
        </div>
        {
          liveMethods.map((m) => (
            <div
              class="start-panel"
              id={`panel-${m.id}`}
              role="tabpanel"
              data-panel={m.id}
              aria-labelledby={`tab-${m.id}`}
              aria-hidden={m.id === defaultMethod ? 'false' : 'true'}
            >
              <div class="start-cmd-box">
                <code class="start-cmd mono">{m.cmd}</code>
                <button
                  class="mono start-copy"
                  type="button"
                  data-copy={m.cmd}
                  aria-label={`Copy: ${m.cmd}`}
                >
                  copy
                </button>
              </div>
              <p class="dim start-note">{m.note}</p>
            </div>
          ))
        }
      </section>

      <p class="mono start-meta dim">
        MIT or Apache-2.0 ·
        <a href="https://github.com/astrid-runtime/astrid">Runtime</a> ·
        <a href="https://github.com/unicity-aos/aos-ce/releases">AOS releases</a>
      </p>
    </header>

    <section class="start-links">
      <a class="card start-link" href="/developers/get-started/">
        <span class="mono start-link-k">Develop</span>
        <span>Build a capsule against the AOS workspace</span>
      </a>
      <a class="card start-link" href="/how-it-works/">
        <span class="mono start-link-k">Explore</span>
        <span>See how agents safely build new abilities</span>
      </a>
    </section>
  </main>
</Base>

<style>
  .start {
    padding-block: calc(var(--s-6) + 2rem) var(--s-7);
  }

  .start-hero {
    max-width: 52rem;
  }

  .start-hero h1 {
    font-family: var(--font-display);
    font-size: var(--step-5);
    font-weight: 400;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    line-height: 0.95;
    margin-block: var(--s-2) var(--s-3);
  }

  .start-lede {
    max-width: 48ch;
    margin-bottom: var(--s-4);
  }

  .start-install {
    position: relative;
    margin-block: var(--s-4) var(--s-3);
    padding: var(--s-3) var(--s-3) var(--s-4);
  }

  .start-anchor {
    position: absolute;
    top: -5rem;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .start-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem var(--s-1);
    border-bottom: 1px solid var(--line);
    margin-bottom: var(--s-3);
    padding-bottom: 0;
  }

  .start-tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-dim);
    font-size: var(--step--1);
    padding: 0.55em 0.85em 0.75em;
    margin-bottom: -1px;
    cursor: pointer;
    transition:
      color var(--t-fast) var(--ease-out),
      border-color var(--t-fast) var(--ease-out);
  }

  .start-tab:hover {
    color: var(--text);
  }

  .start-tab[aria-selected='true'] {
    color: var(--capsule);
    border-bottom-color: var(--capsule);
  }

  .start-tab:focus-visible {
    outline: 1px solid var(--capsule);
    outline-offset: 2px;
  }

  .start-panel {
    display: none;
    gap: var(--s-2);
  }

  .start-panel[aria-hidden='false'] {
    display: grid;
  }

  .start-cmd-box {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--s-2);
    padding: var(--s-3);
    border-radius: 10px;
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    border: 1px solid var(--line);
  }

  .start-cmd {
    flex: 1 1 16rem;
    font-size: clamp(0.78rem, 0.7rem + 0.35vw, 0.95rem);
    color: var(--bus);
    overflow-wrap: anywhere;
    line-height: 1.45;
    user-select: all;
  }

  .start-copy {
    flex: none;
    background: none;
    border: 1px solid var(--line-bright);
    border-radius: 6px;
    color: var(--text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.45em 0.9em;
    cursor: pointer;
    transition:
      color var(--t-fast) var(--ease-out),
      border-color var(--t-fast) var(--ease-out),
      background var(--t-fast) var(--ease-out);
  }

  .start-copy:hover {
    color: var(--text);
    border-color: var(--capsule);
  }

  .start-copy[data-done] {
    color: var(--capsule);
    border-color: color-mix(in srgb, var(--capsule) 50%, transparent);
    background: color-mix(in srgb, var(--capsule) 12%, transparent);
  }

  .start-note {
    font-size: var(--step--1);
    line-height: 1.55;
    max-width: 58ch;
  }

  .start-meta {
    font-size: var(--step--1);
  }

  .start-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: var(--s-3);
    margin-top: var(--s-6);
  }

  .start-link {
    display: grid;
    gap: 0.5rem;
    color: var(--text);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .start-link:hover {
    text-decoration: none;
    border-color: var(--capsule);
  }

  .start-link-k {
    color: var(--capsule);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>

<script>
  function selectMethod(install: HTMLElement, id: string): void {
    install.dataset.method = id;
    for (const b of install.querySelectorAll<HTMLElement>('[data-tab]')) {
      const on = b.dataset.tab === id;
      b.setAttribute('aria-selected', String(on));
      b.tabIndex = on ? 0 : -1;
    }
    for (const p of install.querySelectorAll<HTMLElement>('[data-panel]')) {
      p.setAttribute('aria-hidden', String(p.dataset.panel !== id));
    }
  }

  function wire(): void {
    const install = document.getElementById('install');
    if (!install || install.dataset.wired) return;
    install.dataset.wired = '1';

    install.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest<HTMLElement>('[data-tab]');
      if (t?.dataset.tab) selectMethod(install, t.dataset.tab);
    });

    install.querySelector('.start-tabs')?.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key !== 'ArrowRight' && ke.key !== 'ArrowLeft') return;
      const tabs = [...install.querySelectorAll<HTMLElement>('[data-tab]')];
      const i = tabs.findIndex((t) => t.getAttribute('aria-selected') === 'true');
      if (i < 0) return;
      ke.preventDefault();
      const next = ke.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
      const id = tabs[next]?.dataset.tab;
      if (id) {
        selectMethod(install, id);
        tabs[next]?.focus();
      }
    });

    const hash = location.hash.replace(/^#/, '');
    if (hash && install.querySelector(`[data-panel="${hash}"]`)) {
      selectMethod(install, hash);
    }

    install.querySelectorAll<HTMLButtonElement>('.start-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copy ?? '');
          btn.textContent = 'copied';
          btn.dataset.done = '1';
          setTimeout(() => {
            btn.textContent = 'copy';
            delete btn.dataset.done;
          }, 1400);
        } catch {
          /* command is user-selectable */
        }
      });
    });
  }

  wire();
  document.addEventListener('astro:page-load', wire);
</script>
