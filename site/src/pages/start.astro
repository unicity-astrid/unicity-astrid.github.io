---
import Base from '../layouts/Base.astro';

/** Install page — command in the hero, one paste per tab. Keep RELEASE in
 *  sync with the published Homebrew / crates.io line when it moves. */

const RELEASE = 'v0.9.4';

/**
 * One paste each. Layout:
 *   One command  → shell installs *and* upgrades; detects hosts (new ones wire on re-run)
 *   Homebrew / Cargo → package-manager upgrade/install paths (not the shell)
 *   Claude / Grok / Codex → marketplace plugin install only (base via One command)
 */
const methods = [
  {
    id: 'one',
    label: 'One command',
    cmd: 'curl -fsSL https://astridos.org/install.sh | sh',
    note: 'One command: CLI, base, then your coding hosts — it lists what it detects and asks once (Enter = wire all). Re-run to upgrade.',
  },
  {
    id: 'brew',
    label: 'Homebrew',
    cmd: 'brew upgrade unicity-astrid/tap/astrid || brew install unicity-astrid/tap/astrid',
    note: `CLI only · ${RELEASE}. Prefer One command for releases → ~/.astrid/bin plus host plugins.`,
  },
  {
    id: 'cargo',
    label: 'Cargo',
    cmd: 'cargo install astrid',
    note: 'CLI only · builds latest from crates.io (re-run to upgrade). Host plugins: use One command after.',
  },
  {
    id: 'claude',
    label: 'Claude Code',
    cmd: 'claude plugin marketplace add unicity-astrid/oracles && claude plugin install astrid@astrid-oracles',
    note: 'Editor plugin only (name: astrid). Base runtime + distro: One command first, or re-run after Claude is installed.',
  },
  {
    id: 'grok',
    label: 'Grok Build',
    cmd: 'grok plugin marketplace add unicity-astrid/oracles && grok plugin install astrid@unicity-astrid/oracles --trust',
    note: 'Editor plugin only (name: astrid · pinned by repo, not marketplace name). Base runtime + distro: One command first, or re-run after Grok is installed.',
  },
  {
    id: 'codex',
    label: 'Codex',
    cmd: 'codex plugin marketplace add unicity-astrid/oracles && codex plugin add astrid@astrid-oracles',
    note: 'Editor plugin only (name: astrid · .agents/plugins; codex uses `add`, not `install`). Base runtime + distro: One command first.',
  },
] as const;

const defaultMethod = 'one';
---

<Base
  title="Install Unicity Astrid OS"
  description="One command installs and upgrades Unicity Astrid OS, plus optional host plugins for Claude, Grok, and Codex."
>
  <main class="start wrap">
    <header class="start-hero">
      <p class="eyebrow">Install</p>
      <div class="start-name-row">
        <h1>Unicity Astrid OS</h1>
        <span class="mono start-ver">{RELEASE}</span>
      </div>
      <p class="prose dim start-lede">
        One command installs and upgrades. Host plugins for Claude Code, Grok
        Build, and Codex wire when those apps are on the machine — re-run after
        you add one. Prefer to feel it first?
        <a href="/playground/">Playground</a> runs the real kernel in this tab.
      </p>

      <section
        class="card start-install"
        id="install"
        data-method={defaultMethod}
        aria-label="Install command"
      >
        {
          methods.map((m) => (
            <span id={m.id} class="start-anchor" aria-hidden="true" />
          ))
        }
        <div class="start-tabs" role="tablist" aria-label="Install method">
          {
            methods.map((m) => (
              <button
                class="mono start-tab"
                role="tab"
                type="button"
                id={`tab-${m.id}`}
                data-tab={m.id}
                aria-selected={m.id === defaultMethod ? 'true' : 'false'}
                aria-controls={`panel-${m.id}`}
                tabindex={m.id === defaultMethod ? 0 : -1}
              >
                {m.label}
              </button>
            ))
          }
        </div>
        {
          methods.map((m) => (
            <div
              class="start-panel"
              id={`panel-${m.id}`}
              role="tabpanel"
              data-panel={m.id}
              aria-labelledby={`tab-${m.id}`}
              aria-hidden={m.id === defaultMethod ? 'false' : 'true'}
            >
              <div class="start-cmd-box">
                <code class="start-cmd mono">{m.cmd}</code>
                <button
                  class="mono start-copy"
                  type="button"
                  data-copy={m.cmd}
                  aria-label={`Copy: ${m.cmd}`}
                >
                  copy
                </button>
              </div>
              <p class="dim start-note">{m.note}</p>
            </div>
          ))
        }
      </section>

      <p class="mono start-meta dim">
        MIT or Apache-2.0 ·
        <a href="https://github.com/unicity-astrid/astrid">GitHub</a> ·
        <a href="https://github.com/unicity-astrid/oracles">plugins</a> ·
        <a href="https://crates.io/crates/astrid">crates.io</a> ·
        <a href="/book/">The book</a>
      </p>
    </header>

    <section class="start-links">
      <a class="card start-link" href="/playground/">
        <span class="mono start-link-k">No install</span>
        <span>Write a capsule in this tab against the live kernel</span>
      </a>
      <a class="card start-link" href="/book/">
        <span class="mono start-link-k">The book</span>
        <span>How the machine works, part by part</span>
      </a>
      <a class="card start-link" href="https://github.com/unicity-astrid/oracles">
        <span class="mono start-link-k">Plugins</span>
        <span>Claude · Grok · Codex for Unicity Astrid OS</span>
      </a>
      <a class="card start-link" href="/siri/">
        <span class="mono start-link-k">Hey Siri</span>
        <span>Ask the book by voice on any iPhone</span>
      </a>
    </section>
  </main>
</Base>

<style>
  .start {
    padding-block: calc(var(--s-6) + 2rem) var(--s-7);
  }

  .start-hero {
    max-width: 52rem;
  }

  .start-name-row {
    display: flex;
    align-items: baseline;
    gap: var(--s-2);
    margin-block: var(--s-2) var(--s-3);
  }

  .start-hero h1 {
    font-family: var(--font-display);
    font-size: var(--step-5);
    font-weight: 400;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    line-height: 0.95;
  }

  .start-ver {
    font-size: var(--step--1);
    color: var(--capsule);
    border: 1px solid color-mix(in srgb, var(--capsule) 40%, transparent);
    border-radius: 999px;
    padding: 0.15em 0.7em;
    transform: translateY(-0.15em);
  }

  .start-lede {
    max-width: 48ch;
    margin-bottom: var(--s-4);
  }

  .start-install {
    position: relative;
    margin-block: var(--s-4) var(--s-3);
    padding: var(--s-3) var(--s-3) var(--s-4);
  }

  .start-anchor {
    position: absolute;
    top: -5rem;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .start-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem var(--s-1);
    border-bottom: 1px solid var(--line);
    margin-bottom: var(--s-3);
    padding-bottom: 0;
  }

  .start-tab {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-dim);
    font-size: var(--step--1);
    padding: 0.55em 0.85em 0.75em;
    margin-bottom: -1px;
    cursor: pointer;
    transition:
      color var(--t-fast) var(--ease-out),
      border-color var(--t-fast) var(--ease-out);
  }

  .start-tab:hover {
    color: var(--text);
  }

  .start-tab[aria-selected='true'] {
    color: var(--capsule);
    border-bottom-color: var(--capsule);
  }

  .start-tab:focus-visible {
    outline: 1px solid var(--capsule);
    outline-offset: 2px;
  }

  .start-panel {
    display: none;
    gap: var(--s-2);
  }

  .start-panel[aria-hidden='false'] {
    display: grid;
  }

  .start-cmd-box {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--s-2);
    padding: var(--s-3);
    border-radius: 10px;
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    border: 1px solid var(--line);
  }

  .start-cmd {
    flex: 1 1 16rem;
    font-size: clamp(0.78rem, 0.7rem + 0.35vw, 0.95rem);
    color: var(--bus);
    overflow-wrap: anywhere;
    line-height: 1.45;
    user-select: all;
  }

  .start-copy {
    flex: none;
    background: none;
    border: 1px solid var(--line-bright);
    border-radius: 6px;
    color: var(--text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.45em 0.9em;
    cursor: pointer;
    transition:
      color var(--t-fast) var(--ease-out),
      border-color var(--t-fast) var(--ease-out),
      background var(--t-fast) var(--ease-out);
  }

  .start-copy:hover {
    color: var(--text);
    border-color: var(--capsule);
  }

  .start-copy[data-done] {
    color: var(--capsule);
    border-color: color-mix(in srgb, var(--capsule) 50%, transparent);
    background: color-mix(in srgb, var(--capsule) 12%, transparent);
  }

  .start-note {
    font-size: var(--step--1);
    line-height: 1.55;
    max-width: 58ch;
  }

  .start-meta {
    font-size: var(--step--1);
  }

  .start-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: var(--s-3);
    margin-top: var(--s-6);
  }

  .start-link {
    display: grid;
    gap: 0.5rem;
    color: var(--text);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .start-link:hover {
    text-decoration: none;
    border-color: var(--capsule);
  }

  .start-link-k {
    color: var(--capsule);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>

<script>
  function selectMethod(install: HTMLElement, id: string): void {
    install.dataset.method = id;
    for (const b of install.querySelectorAll<HTMLElement>('[data-tab]')) {
      const on = b.dataset.tab === id;
      b.setAttribute('aria-selected', String(on));
      b.tabIndex = on ? 0 : -1;
    }
    for (const p of install.querySelectorAll<HTMLElement>('[data-panel]')) {
      p.setAttribute('aria-hidden', String(p.dataset.panel !== id));
    }
  }

  function wire(): void {
    const install = document.getElementById('install');
    if (!install || install.dataset.wired) return;
    install.dataset.wired = '1';

    install.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest<HTMLElement>('[data-tab]');
      if (t?.dataset.tab) selectMethod(install, t.dataset.tab);
    });

    install.querySelector('.start-tabs')?.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key !== 'ArrowRight' && ke.key !== 'ArrowLeft') return;
      const tabs = [...install.querySelectorAll<HTMLElement>('[data-tab]')];
      const i = tabs.findIndex((t) => t.getAttribute('aria-selected') === 'true');
      if (i < 0) return;
      ke.preventDefault();
      const next = ke.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
      const id = tabs[next]?.dataset.tab;
      if (id) {
        selectMethod(install, id);
        tabs[next]?.focus();
      }
    });

    const hash = location.hash.replace(/^#/, '');
    if (hash && install.querySelector(`[data-panel="${hash}"]`)) {
      selectMethod(install, hash);
    }

    install.querySelectorAll<HTMLButtonElement>('.start-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copy ?? '');
          btn.textContent = 'copied';
          btn.dataset.done = '1';
          setTimeout(() => {
            btn.textContent = 'copy';
            delete btn.dataset.done;
          }, 1400);
        } catch {
          /* command is user-selectable */
        }
      });
    });
  }

  wire();
  document.addEventListener('astro:page-load', wire);
</script>
