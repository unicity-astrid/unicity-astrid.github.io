---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/tokens.css';
import '../styles/base.css';
import Hud from '../components/Hud.astro';
import AgentPill from '../components/AgentPill.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#07080D" />
  </head>
  <body>
    <astrid-rail aria-hidden="true"></astrid-rail>
    <nav class="site-tabs mono" aria-label="Site">
      <a href="/" class="site-mark">ASTRID</a>
      <a href="/book/">the book</a>
      <a href="/playground/">playground</a>
    </nav>
    <Hud />
    <AgentPill />
    <slot />
    <script>
      import { bootKernel } from '../scripts/kernel';
      import { bootSectionCapsules } from '../scripts/section-capsules';
      import '../scripts/rail';
      // Boot the real kernel after first paint; the HUD flips when it lands.
      // Then instantiate the section capsules that ship with this build.
      requestAnimationFrame(() => {
        void bootKernel().then((bridge) => {
          if (bridge) void bootSectionCapsules(bridge);
        });
      });
    </script>
    <style>
      .site-tabs {
        position: fixed;
        top: var(--s-2);
        left: calc(var(--rail-x) + 1.25rem);
        z-index: 100;
        display: flex;
        align-items: baseline;
        gap: var(--s-3);
        font-size: var(--step--1);
      }

      .site-tabs a {
        color: var(--text-dim);
      }

      .site-tabs a:hover {
        color: var(--text);
        text-decoration: none;
      }

      .site-mark {
        color: var(--text) !important;
        letter-spacing: 0.28em;
        font-weight: 500;
      }

      .site-soon {
        color: var(--text-faint);
        cursor: default;
      }

      @media (max-width: 640px) {
        .site-tabs {
          gap: var(--s-2);
        }
      }
    </style>
  </body>
</html>
