---
import '@fontsource/anton/400.css';
import '@fontsource-variable/inter';
import '@fontsource/geist-mono/400.css';
import '@fontsource/geist-mono/600.css';
import '../styles/tokens.css';
import '../styles/base.css';
import { ClientRouter } from 'astro:transitions';
import Hud from '../components/Hud.astro';
import AgentPill from '../components/AgentPill.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#060606" />
    <ClientRouter />
  </head>
  <body>
    <!-- The chrome persists across navigations: the same kernel, the same
         installed capsules, the same downloaded model, page after page. The
         page never reloads; only the content swaps. -->
    <astrid-rail aria-hidden="true" transition:persist="rail"></astrid-rail>
    <nav class="site-tabs mono" aria-label="Site" transition:persist="tabs">
      <a href="/" class="site-mark">ASTRID</a>
      <a href="/build/">build</a>
      <a href="/how-it-works/">how it works</a>
      <a href="/registry/">registry</a>
      <a href="/playground/">playground</a>
      <a href="/book/">the book</a>
      <a href="/start/">install</a>
    </nav>
    <div transition:persist="hud"><Hud /></div>
    <div transition:persist="agent-pill"><AgentPill /></div>
    <slot />
    <script>
      import { bootKernel } from '../scripts/kernel';
      import { bootSectionCapsules } from '../scripts/section-capsules';
      import { bootFleet } from '../scripts/fleet-host';
      import '../scripts/rail';
      // Boot the real kernel after first paint; the HUD flips when it lands.
      // Then instantiate the section capsules and the agentic fleet that
      // ship with this build.
      requestAnimationFrame(() => {
        void bootKernel().then((bridge) => {
          if (bridge) {
            void bootSectionCapsules(bridge);
            void bootFleet(bridge);
          }
        });
      });
    </script>
    <style>
      .site-tabs {
        position: fixed;
        top: var(--s-2);
        left: calc(var(--rail-x) + 1.25rem);
        z-index: 100;
        display: flex;
        align-items: baseline;
        gap: var(--s-3);
        font-size: var(--step--1);
      }

      .site-tabs a {
        color: var(--text-dim);
      }

      .site-tabs a:hover {
        color: var(--text);
        text-decoration: none;
      }

      .site-mark {
        color: var(--text) !important;
        letter-spacing: 0.28em;
        font-weight: 500;
      }

      .site-soon {
        color: var(--text-faint);
        cursor: default;
      }

      /* Phones: the floating links become a real bar — full width, blurred
         backdrop so they survive sitting over the hero, scrollable sideways
         instead of wrapping over content, and clear of the notch. */
      @media (max-width: 640px) {
        .site-tabs {
          left: 0;
          right: 0;
          top: 0;
          gap: var(--s-2);
          padding: calc(var(--s-1) + env(safe-area-inset-top, 0px)) var(--s-2) var(--s-1);
          overflow-x: auto;
          white-space: nowrap;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          background: color-mix(in srgb, var(--bg) 82%, transparent);
          backdrop-filter: blur(10px);
          -webkit-backdrop-filter: blur(10px);
          border-bottom: 1px solid var(--line);
        }

        .site-tabs::-webkit-scrollbar {
          display: none;
        }

        .site-tabs a {
          flex: none;
        }
      }
    </style>
  </body>
</html>
