---
import claudeMark from '../assets/brands/claude.svg?raw';
import codexMark from '../assets/brands/codex.svg?raw';
import grokMark from '../assets/brands/grok.svg?raw';

interface Props {
  agent: 'claude' | 'grok' | 'codex';
  showName?: boolean;
}

const { agent, showName = true } = Astro.props;
const names = {
  claude: 'Claude Code',
  grok: 'Grok Build',
  codex: 'Codex',
} as const;
const marks = {
  claude: claudeMark,
  grok: grokMark,
  codex: codexMark,
} as const;
const mark = marks[agent];
---

<span class="agent-mark" data-agent={agent} aria-label={names[agent]}>
  <span class="agent-icon" aria-hidden="true" set:html={mark} />
  {showName && <span class="agent-name">{names[agent]}</span>}
</span>

<style>
  .agent-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.65em;
    min-width: 0;
    color: var(--text);
  }

  .agent-icon {
    display: inline-flex;
    width: 1.35em;
    height: 1.35em;
    flex: none;
  }

  .agent-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .agent-name {
    font-size: 0.92em;
    font-weight: 600;
    white-space: nowrap;
  }
</style>
