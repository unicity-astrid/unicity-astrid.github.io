---
/** Section — who it is for, linking each audience to the product path. */
// the "bring your existing agent" audience has its own section (SceneBring);
// these are the remaining seats
const audiences = [
  {
    kicker: 'You juggle several AIs',
    title: 'They finally work together.',
    body: 'Today every agent is its own silo, with its own tools and its own amnesia. On Unicity AOS they share one message line, one toolbox, one memory, and one set of rules. Different brains, one workshop.',
    href: '/how-it-works/',
    link: 'See the architecture',
  },
  {
    kicker: 'You host AI for others',
    title: 'Thousands of tenants. One server.',
    body: 'Every tenant is walled off by construction, while the parts they all use are shared instead of duplicated: dramatically less compute per tenant. The density benchmark is on the roadmap; the isolation boundary is implemented in Astrid Runtime today.',
    href: '/how-it-works/',
    link: 'See the isolation model',
  },
  {
    kicker: 'You build tools',
    title: 'Build once. Every AI gains it.',
    body: 'Build one signed capsule and reuse it across AOS compositions, with the permissions it needs declared up front. The planned registry will make that distribution path public. No per-vendor plugins. One part, everywhere.',
    href: '/registry/',
    link: 'Browse capsules',
  },
];
---

<section class="aud hairline-top" id="audiences" data-scene>
  <div class="wrap">
    <p class="eyebrow">07 · who rides it</p>
    <h2 class="aud-title">Different seats,<br />same machine.</h2>
    <div class="aud-rows">
      {
        audiences.map((a) => (
          <a class="aud-row" href={a.href}>
            <p class="mono aud-kicker">{a.kicker}</p>
            <div class="aud-body">
              <h3>{a.title}</h3>
              <p class="dim">{a.body}</p>
            </div>
            <span class="mono aud-link" aria-hidden="true">{a.link} →</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* editorial rows, not a card grid: the demos above already made the
     argument — this is the index of doors, kept quiet on purpose */
  .aud {
    padding-block: var(--s-8);
  }

  .aud-title {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-5);
  }

  .aud-rows {
    display: grid;
  }

  .aud-row {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(0, 7fr) minmax(0, 2fr);
    gap: var(--s-3);
    align-items: baseline;
    padding: var(--s-3) var(--s-2);
    border-top: 1px solid var(--line);
    color: inherit;
    transition: background var(--t-fast) var(--ease-out);
  }

  .aud-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .aud-row:hover {
    text-decoration: none;
    background: color-mix(in srgb, var(--bg-raised) 55%, transparent);
  }

  @media (max-width: 900px) {
    .aud-row {
      grid-template-columns: 1fr;
      gap: var(--s-1);
    }
  }

  .aud-kicker {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--capsule);
  }

  .aud-body h3 {
    font-size: var(--step-1);
    margin-bottom: 0.3em;
  }

  .aud-body .dim {
    font-size: var(--step--1);
    line-height: 1.6;
    max-width: 52ch;
  }

  .aud-link {
    font-size: var(--step--1);
    justify-self: end;
    color: var(--text-dim);
  }

  @media (max-width: 900px) {
    .aud-link {
      justify-self: start;
    }
  }

  .aud-row:hover .aud-link {
    color: var(--text);
  }
</style>
