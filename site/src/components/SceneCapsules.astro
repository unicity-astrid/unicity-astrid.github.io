---
/** Section 3 — "Everything else is a capsule."
 *  The capsules clamp onto the rail one by one as they scroll into view;
 *  each chip pairs a part with what it does for you, in plain words. */
const capsules = [
  { name: 'the AI', does: 'The brain. Swap it for any model, any vendor' },
  { name: 'the agent', does: 'thinks in steps, uses tools, reports back' },
  { name: 'the tools', does: 'Files, web, commands, each one sealed' },
  { name: 'the memory', does: 'what it learned yesterday, still there today' },
  { name: 'the conversation', does: 'every exchange, kept and resumable' },
  { name: 'the skills', does: 'how-to knowledge any agent can pick up' },
];
---

<section class="scene wrap" id="capsules" data-scene>
  <div class="capsule-rack">
    {
      capsules.map((c) => (
        <div class="capsule-row">
          <span class="dock-chip" data-dock={c.name}>{c.name}</span>
          <span class="topic">{c.does}</span>
        </div>
      ))
    }
  </div>
  <div class="scene-copy prose">
    <p class="eyebrow">02 · the parts</p>
    <h2>Every ability<br />is a <span class="capsule-word">capsule</span>.</h2>
    <p>
      The AI model. The memory. Every tool and every skill. In Unicity Astrid OS each one
      is a sealed part called a capsule: it snaps onto the engine, does its one
      job, and can be swapped without rebuilding anything, or trusted with
      anything it wasn't given.
    </p>
    <p>
      Swap the model capsule and the same assistant runs on a different AI
      tomorrow, yours included. Add a tool capsule and every agent in the house
      can use it. Nothing is welded shut.
    </p>
  </div>
</section>

<style>
  .scene {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
    gap: var(--s-5);
    align-items: center;
    padding-block: var(--s-8);
  }

  @media (max-width: 900px) {
    .scene {
      grid-template-columns: 1fr;
    }

    .capsule-rack {
      order: 2;
    }
  }

  .scene-copy h2 {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  .scene-copy p + p {
    margin-top: var(--s-2);
  }

  .capsule-word {
    color: var(--capsule);
  }

  .capsule-rack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-3);
  }

  .capsule-row {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    min-width: 0;
  }

  .topic {
    font-size: var(--step--1);
    color: var(--text-dim);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 620px) {
    .topic {
      display: none;
    }
  }
</style>
