---
/**
 * Fixed kernel HUD. Every number here is read from the real kernel bridge;
 * before boot it shows "booting", and if wasm is unavailable it says so
 * plainly. Clicking opens a drawer with the live audit tail and a note on
 * how to verify the kernel in devtools.
 */
---

<button id="hud" class="hud mono" aria-expanded="false" aria-controls="hud-drawer" title="What's running this page">
  <span id="hud-dot" class="hud-dot" data-state="booting" aria-hidden="true"></span>
  <span id="hud-text">Starting the AOS engine…</span>
</button>

<aside
  id="hud-drawer"
  class="hud-drawer card"
  role="dialog"
  aria-modal="false"
  aria-labelledby="hud-drawer-title"
  hidden
>
  <header class="hud-drawer-head">
    <h2 class="mono" id="hud-drawer-title">Under the hood</h2>
    <button id="hud-close" class="hud-close mono" type="button" aria-label="Close panel">✕</button>
  </header>
  <dl class="hud-facts mono">
    <div><dt>State</dt><dd id="hud-f-state">Booting</dd></div>
    <div><dt>Build</dt><dd id="hud-f-build">–</dd></div>
    <div><dt>Events routed</dt><dd id="hud-f-events">–</dd></div>
    <div><dt>Audit entries</dt><dd id="hud-f-audit">–</dd></div>
  </dl>
  <h3 class="mono dim">Installed capsules</h3>
  <ul id="hud-capsules" class="hud-capsules mono"></ul>
  <p class="hud-note dim hud-capsule-note">
    Rust capsules (astrid-sdk, compiled to WebAssembly) running the page's
    behaviour. Uninstall one and the part of the page it powers stops.
    Install and uninstall mint and revoke capability tokens on the audit
    chain. Native installs additionally verify publisher signatures.
  </p>
  <button id="hud-model-remove" class="hud-model-remove mono" type="button" hidden>
    Remove downloaded model
  </button>
  <p id="hud-model-remove-status" class="hud-note dim" role="status" aria-live="polite" hidden></p>
  <h3 class="mono dim">Audit tail</h3>
  <ol id="hud-audit" class="hud-audit mono" reversed></ol>
  <p class="hud-note dim">
    This page is static: GitHub Pages, no backend, no demo server. The embedded
    AOS engine is not simulated: open devtools, choose Network, and find <code>kernel_web_bg.wasm</code>, the
    same <code>astrid-kernel</code> crate the daemon ships, booted in this
    tab. Every check and every audit entry here is the runtime enforcing its
    own rules. That is the point. The security model is not a cloud
    promise; it holds wherever the runtime runs, including here.
  </p>
</aside>

<style>
  .hud {
    position: fixed;
    top: var(--s-2);
    right: var(--s-2);
    z-index: 100;
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.45em 0.9em;
    font-size: var(--step--1);
    color: var(--text-dim);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border: 1px solid var(--line);
    border-radius: 999px;
    backdrop-filter: blur(12px);
    transition: border-color var(--t-fast) var(--ease-out);
  }

  .hud:hover {
    border-color: var(--line-bright);
    color: var(--text);
  }

  .hud-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-faint);
    flex: none;
  }

  .hud-dot[data-state='online'] {
    background: var(--bus);
    box-shadow: 0 0 8px var(--bus);
    animation: hud-pulse 2.4s ease-in-out infinite;
  }

  .hud-dot[data-state='offline'] {
    background: var(--text-faint);
  }

  @keyframes hud-pulse {
    50% {
      box-shadow: 0 0 2px var(--bus);
    }
  }

  .hud-drawer {
    position: fixed;
    top: calc(var(--s-2) + 3rem);
    right: var(--s-2);
    z-index: 100;
    width: min(26rem, calc(100vw - 2 * var(--s-2)));
    max-height: min(34rem, 78vh);
    overflow: auto;
    padding: var(--s-3);
  }

  /* Phones: the nav is a full-width bar up top, so the status chip and its
     drawer drop below it instead of colliding. */
  @media (max-width: 900px) {
    .hud {
      top: calc(env(safe-area-inset-top, 0px) + 2.9rem);
    }

    .hud-drawer {
      top: calc(env(safe-area-inset-top, 0px) + 5.6rem);
      max-height: 62vh;
    }
  }

  .hud-drawer-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--s-2);
  }

  .hud-drawer-head h2 {
    font-size: var(--step-0);
    letter-spacing: 0.1em;
  }

  .hud-close {
    background: none;
    border: none;
    color: var(--text-dim);
    padding: 0.2em 0.4em;
  }

  .hud-close:hover {
    color: var(--text);
  }

  .hud-facts {
    display: grid;
    gap: 0.35em;
    font-size: var(--step--1);
    margin-bottom: var(--s-3);
  }

  .hud-facts div {
    display: flex;
    justify-content: space-between;
    gap: var(--s-2);
  }

  .hud-facts dt {
    color: var(--text-faint);
  }

  .hud-facts dd {
    font-variant-numeric: tabular-nums;
  }

  .hud-drawer h3 {
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--s-1);
  }

  .hud-capsules {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.3em;
    font-size: 0.72rem;
    margin-bottom: var(--s-1);
  }

  .hud-capsules :global(li) {
    display: flex;
    align-items: center;
    gap: 0.8em;
    padding: 0.35em 0.5em;
    border: 1px solid var(--line);
    border-radius: 6px;
  }

  .hud-capsules :global(.cap-name) {
    color: var(--capsule);
    flex: none;
  }

  .hud-capsules :global(.cap-blurb) {
    color: var(--text-faint);
    flex: 1;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .hud-capsules :global(.cap-toggle) {
    flex: none;
    background: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-dim);
    font: inherit;
    font-size: 0.9em;
    padding: 0.15em 0.7em;
    cursor: pointer;
  }

  .hud-capsules :global(.cap-toggle:hover) {
    color: var(--text);
    border-color: var(--line-bright);
  }

  .hud-capsules :global(.cap-toggle[data-state='installed']) {
    color: var(--grant);
    border-color: color-mix(in srgb, var(--grant) 40%, transparent);
  }

  .hud-capsules :global(.cap-toggle[data-state='uninstalled']) {
    color: var(--deny);
    border-color: color-mix(in srgb, var(--deny) 40%, transparent);
  }

  .hud-capsule-note {
    margin-bottom: var(--s-3);
  }

  .hud-model-remove {
    background: none;
    border: 1px solid color-mix(in srgb, var(--deny) 40%, transparent);
    border-radius: 999px;
    color: var(--deny);
    font: inherit;
    font-size: 0.72rem;
    padding: 0.4em 1em;
    cursor: pointer;
    margin-bottom: var(--s-3);
  }

  .hud-model-remove:hover:not(:disabled) {
    border-color: var(--deny);
  }

  .hud-model-remove:disabled {
    opacity: 0.6;
    cursor: default;
  }

  .hud-audit {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.3em;
    font-size: 0.72rem;
    margin-bottom: var(--s-3);
  }

  .hud-audit :global(li) {
    display: flex;
    gap: 0.8em;
    padding: 0.35em 0.5em;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
  }

  .hud-audit :global(.hash) {
    color: var(--audit);
    flex: none;
  }

  .hud-audit :global(.action) {
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hud-note {
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .hud-note code {
    color: var(--bus);
    font-size: 0.95em;
  }
</style>

<script>
  import { onKernel, kernel } from '../scripts/kernel';
  import {
    SECTION_CAPSULES,
    capsuleState,
    onSectionCapsules,
    toggleCapsule,
  } from '../scripts/section-capsules';
  import { removeModel } from '../scripts/local-agent';

  const $ = (id: string) => document.getElementById(id)!;
  const hud = $('hud');
  const drawer = $('hud-drawer');
  const closeButton = $('hud-close') as HTMLButtonElement;
  const dot = $('hud-dot');
  const text = $('hud-text');
  const modelRemove = $('hud-model-remove') as HTMLButtonElement;
  const modelRemoveStatus = $('hud-model-remove-status');

  let commit = '';
  let ticker: number | undefined;

  onKernel((status, bridge) => {
    dot.dataset.state = status;
    $('hud-f-state').textContent = status;
    if (status === 'online' && bridge) {
      commit = bridge.kernelCommit();
      $('hud-f-build').textContent = `astrid-kernel@${commit}`;
      startTicker();
    } else if (status === 'offline') {
      text.textContent = 'Not running in this browser';
    }
  });

  function startTicker(): void {
    if (ticker !== undefined) return;
    const tick = async () => {
      const bridge = kernel();
      if (!bridge) return;
      const events = bridge.eventsRouted();
      text.textContent = `Live · ${events} messages carried`;
      $('hud-f-events').textContent = String(events);
      // never fake the audit surface when the browser build lacks it
      $('hud-f-audit').textContent = bridge.auditLen
        ? String(await bridge.auditLen())
        : 'Not in the browser build yet';
      if (!drawer.hidden) await refreshAudit();
    };
    void tick();
    ticker = window.setInterval(() => void tick(), 1500);
  }

  async function refreshAudit(): Promise<void> {
    const bridge = kernel();
    if (!bridge?.auditTail) {
      const list = $('hud-audit');
      if (!list.childElementCount) {
        const li = document.createElement('li');
        li.innerHTML = '<span class="action">The audit ledger isn’t readable in the browser build yet</span>';
        list.append(li);
      }
      return;
    }
    try {
      const entries = JSON.parse(await bridge.auditTail(8)) as Array<Record<string, unknown>>;
      const list = $('hud-audit');
      list.innerHTML = '';
      for (const e of entries.reverse()) {
        const li = document.createElement('li');
        const hash = document.createElement('span');
        hash.className = 'hash';
        hash.textContent = String(e.hash ?? '').slice(0, 8);
        const action = document.createElement('span');
        action.className = 'action';
        action.textContent = String(e.action ?? e.kind ?? '');
        li.append(hash, action);
        list.append(li);
      }
    } catch {
      /* tail stays as-is; next tick retries */
    }
  }

  // ---- section-capsule rack ----
  function capsuleRow(
    name: string,
    blurb: string,
    state: string,
    onToggle: () => void,
  ): HTMLLIElement {
    const li = document.createElement('li');
    const n = document.createElement('span');
    n.className = 'cap-name';
    n.textContent = name;
    const b = document.createElement('span');
    b.className = 'cap-blurb';
    b.textContent = blurb;
    li.append(n, b);
    if (state === 'installed' || state === 'uninstalled') {
      const btn = document.createElement('button');
      btn.className = 'cap-toggle';
      btn.dataset.state = state;
      btn.textContent = state === 'installed' ? 'installed' : 'install';
      btn.addEventListener('click', onToggle);
      li.append(btn);
    } else {
      const off = document.createElement('span');
      off.className = 'cap-blurb';
      off.textContent = state === 'error' ? 'failed to load' : 'not in this build';
      li.append(off);
    }
    return li;
  }

  function renderCapsules(): void {
    const list = $('hud-capsules');
    list.innerHTML = '';
    for (const def of SECTION_CAPSULES) {
      list.append(
        capsuleRow(def.name, def.blurb, capsuleState(def.name), () => void toggleCapsule(def.name)),
      );
    }
  }
  onSectionCapsules(renderCapsules);

  function syncModelRemoval(): void {
    const downloaded =
      localStorage.getItem('aos-agent-optin') === '1' ||
      localStorage.getItem('astrid-agent-optin') === '1';
    modelRemove.hidden = !downloaded;
    if (downloaded) {
      modelRemove.disabled = false;
      modelRemove.textContent = 'Remove downloaded model';
      modelRemoveStatus.hidden = true;
    }
  }

  modelRemove.addEventListener('click', () => {
    const bridge = kernel();
    if (!bridge) {
      modelRemoveStatus.hidden = false;
      modelRemoveStatus.textContent = 'The runtime is unavailable; the model was not removed.';
      return;
    }
    modelRemove.disabled = true;
    modelRemove.textContent = 'Removing model…';
    modelRemoveStatus.hidden = false;
    modelRemoveStatus.textContent = 'Deleting model weights and cache from this browser.';
    void removeModel(bridge)
      .then(() => {
        modelRemove.textContent = 'Model removed';
        modelRemoveStatus.textContent =
          'The downloaded model was removed. Any connected endpoint remains active.';
      })
      .catch((error: unknown) => {
        modelRemove.disabled = false;
        modelRemove.textContent = 'Try removing model again';
        modelRemoveStatus.textContent =
          error instanceof Error ? error.message : 'The browser could not remove the model.';
      });
  });

  hud.addEventListener('click', () => {
    const open = drawer.hidden;
    drawer.hidden = !open;
    hud.setAttribute('aria-expanded', String(open));
    if (open) {
      syncModelRemoval();
      void refreshAudit();
      closeButton.focus();
    }
  });

  function closeDrawer(returnFocus = true): void {
    drawer.hidden = true;
    hud.setAttribute('aria-expanded', 'false');
    if (returnFocus) hud.focus();
  }

  closeButton.addEventListener('click', () => closeDrawer());
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !drawer.hidden) closeDrawer();
  });
</script>
