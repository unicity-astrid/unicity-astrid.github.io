---
/**
 * Decorative background ornament: a dense radial burst of thin dashes,
 * events radiating from the kernel at the (empty) centre. Two depth layers:
 * a soft blurred field behind, a near-sharp field in front, both drifting
 * slowly in opposite directions. Deterministic (seeded, not Math.random) so
 * builds are reproducible. Pure SVG + CSS, no script, aria-hidden; the
 * drift stops under prefers-reduced-motion.
 */
const rand = (i: number, salt: number): number => {
  const x = Math.sin(i * 127.1 + salt * 311.7) * 43758.5453;
  return x - Math.floor(x);
};

// Mostly capsule-purple, with bus-teal, audit-pink, and plain-light accents.
const palette = [
  'var(--capsule)',
  'var(--capsule)',
  'var(--capsule)',
  'var(--bus)',
  'var(--capsule)',
  'var(--audit)',
  'var(--text-dim)',
  'var(--bus)',
];

interface Dash {
  angle: number;
  r: number;
  len: number;
  w: number;
  fill: string;
  opacity: number;
}

function burst(count: number, salt: number, rMin: number, rMax: number): Dash[] {
  return Array.from({ length: count }, (_, i) => {
    const r = rMin + rand(i, salt + 1) * (rMax - rMin);
    // Longer dashes stay near the rim so the centre keeps its void.
    const len = 26 + rand(i, salt + 2) * 130 * ((r - rMin) / (rMax - rMin) * 0.7 + 0.3);
    return {
      angle: rand(i, salt) * 360,
      r,
      len,
      w: 3 + rand(i, salt + 3) * 4.5,
      fill: palette[Math.floor(rand(i, salt + 4) * palette.length)],
      opacity: 0.24 + rand(i, salt + 5) * 0.55,
    };
  });
}

const back = burst(150, 7, 115, 268);
const front = burst(170, 23, 130, 255);
---

<div class="ring-wrap" aria-hidden="true">
  <canvas class="burst-gl" id="burst-gl"></canvas>
  <svg class="ring" id="burst-svg" viewBox="0 0 600 600">
    <g class="layer layer-back">
      {
        back.map((d) => (
          <rect
            x={300 + d.r}
            y={300 - d.w / 2}
            width={d.len}
            height={d.w}
            rx={d.w / 2}
            fill={d.fill}
            opacity={d.opacity * 0.75}
            transform={`rotate(${d.angle} 300 300)`}
          />
        ))
      }
    </g>
    <g class="layer layer-front">
      {
        front.map((d) => (
          <rect
            x={300 + d.r}
            y={300 - d.w / 2}
            width={d.len}
            height={d.w}
            rx={d.w / 2}
            fill={d.fill}
            opacity={d.opacity}
            transform={`rotate(${d.angle} 300 300)`}
          />
        ))
      }
    </g>
  </svg>
</div>

<style>
  /* the eye lives on a fixed, full-viewport layer behind ALL content: it
     follows the visitor down the whole page instead of scrolling away with
     the hero. z-index -1 keeps it above the body background and below
     every in-flow section. */
  .ring-wrap {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    /* lvh, not vh/inset: the mobile URL bar changing the visual viewport
       must NOT resize this layer — every resize clears the WebGL canvas
       for a frame, which reads as flicker while scrolling. Sized to the
       largest viewport, scroll never resizes it; the sliver below the
       fold just crops. */
    height: 100vh;
    height: 100lvh;
    overflow: hidden;
    pointer-events: none;
    z-index: -1;
  }

  .ring {
    position: absolute;
    top: 50%;
    left: 72%;
    width: min(96vmin, 62rem);
    aspect-ratio: 1;
    translate: -50% -50%;
    /* fade the burst out toward its own edge so it never hard-crops */
    mask-image: radial-gradient(circle, black 58%, transparent 80%);
    /* the static fallback can't follow the page; it bows out with the hero */
    opacity: calc(1 - var(--hero-p, 0));
    /* hidden until we KNOW WebGL2 is unavailable — no flash before the live
       eye boots (the [data-gl] attribute is set either way, promptly) */
    display: none;
  }

  .ring-wrap[data-gl='false'] .ring {
    display: block;
  }

  .layer {
    transform-origin: 300px 300px;
  }

  .layer-back {
    filter: blur(8px);
    animation: ring-drift 240s linear infinite;
  }

  .layer-front {
    animation: ring-drift 320s linear infinite reverse;
  }

  @keyframes ring-drift {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .layer {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .ring {
      left: 50%;
      opacity: 0.5;
    }
  }

  .burst-gl {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: none;
  }

  .ring-wrap[data-gl='true'] .burst-gl {
    display: block;
  }

  @media (max-width: 900px) {
    .burst-gl {
      opacity: 0.55;
    }
  }
</style>

<script>
  import { startBurst, type BurstHandle, type BurstPose } from '../scripts/burst-gl';
  import { setBurst } from '../scripts/burst-link';
  import { onKernel, kernel } from '../scripts/kernel';

  // The live 3D burst; the static SVG is the no-WebGL2 fallback (shown only
  // once we KNOW GL failed — never before, so there is no flash of the old
  // ornament while the eye boots). The canvas is re-created on every
  // client-router visit and browsers cap live WebGL contexts, so each visit
  // boots a fresh burst and the swap-out releases the old one.
  let burst: BurstHandle | null = null;
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // The eye's journey, a pure function of scroll position:
  //   AWAKE (top of page)   — off to the right, tilted, idling
  //   RISEN (hero scrolled) — flies up to top-centre, grows, turns to face
  //                           you; only its bottom ~40% stays in frame, a
  //                           crown over the viewport looking down at you
  //   EXIT  (past the hero) — ascends off the top edge in the direction the
  //                           page moves, and is gone. It does not perch.
  // yaw/pitch are the idle glance; gaze blends toward the engine-computed
  // look-at-the-camera rotation, so "facing you" is geometry, never tuning
  const AWAKE: BurstPose = { x: 0.78, y: 0.50, scale: 1.00, yaw: -0.52, pitch: 0.34, gaze: 0.0, alpha: 1.0, spin: 0 };
  const RISEN: BurstPose = { x: 0.50, y: -0.14, scale: 1.50, yaw: 0.00, pitch: 0.00, gaze: 1.0, alpha: 1.0, spin: 1 };
  const EXIT: BurstPose  = { x: 0.50, y: -0.80, scale: 1.50, yaw: 0.00, pitch: 0.00, gaze: 1.0, alpha: 0.0, spin: 1 };

  const smooth = (t: number): number => {
    const c = Math.min(1, Math.max(0, t));
    return c * c * (3 - 2 * c);
  };
  const mix = (a: BurstPose, b: BurstPose, t: number): BurstPose => ({
    x: a.x + (b.x - a.x) * t,
    y: a.y + (b.y - a.y) * t,
    scale: a.scale + (b.scale - a.scale) * t,
    yaw: a.yaw + (b.yaw - a.yaw) * t,
    pitch: a.pitch + (b.pitch - a.pitch) * t,
    gaze: a.gaze + (b.gaze - a.gaze) * t,
    alpha: a.alpha + (b.alpha - a.alpha) * t,
    spin: a.spin + (b.spin - a.spin) * t,
  });

  function targetPose(): BurstPose {
    const hero = document.getElementById('top');
    if (!hero) return AWAKE;
    const r = hero.getBoundingClientRect();
    const span = Math.max(1, r.height - innerHeight);
    // p1: how far through the hero pin. p2: how far past the hero's end —
    // r.bottom stays ≥ viewport height while pinned (so p2 clamps to 0);
    // once the hero unpins the eye ascends out over ~0.6 viewports, moving
    // WITH the content, so it reads as scrolling off rather than vanishing.
    const p1 = smooth(-r.top / span);
    const p2 = smooth((innerHeight - r.bottom) / (0.6 * innerHeight));
    return mix(mix(AWAKE, RISEN, p1), EXIT, p2);
  }

  // The scroll defines where the eye SHOULD be; the rendered pose chases it
  // through a short lag, so quantized wheel notches become glides and the
  // corner at the hero's unpin rounds itself off. The target stays a pure
  // function of scroll, so the journey is still fully reversible.
  let cur: BurstPose | null = null;
  let lastMs = 0;
  function pose(): BurstPose {
    const target = targetPose();
    const now = performance.now();
    const dt = lastMs ? Math.min(0.1, (now - lastMs) / 1000) : 1;
    lastMs = now;
    if (!cur) {
      cur = target;
      return cur;
    }
    cur = mix(cur, target, 1 - Math.exp(-dt / 0.18));
    return cur;
  }

  function wire(): void {
    const canvas = document.getElementById('burst-gl') as HTMLCanvasElement | null;
    if (!canvas || burst) return;
    burst = startBurst(canvas, pose);
    canvas.parentElement?.setAttribute('data-gl', burst ? 'true' : 'false');
    setBurst(burst);
  }
  wire();
  document.addEventListener('astro:page-load', wire);
  document.addEventListener('astro:before-swap', () => {
    burst?.stop();
    burst = null;
    setBurst(null);
  });

  // --hero-p drives the hero text fade and the SVG fallback (set on the
  // root so both the hero and the fixed layer see it). One module-lifetime
  // listener; pages without a hero simply never match.
  let scrollQueued = false;
  function onScrub(): void {
    if (scrollQueued || reduced) return;
    scrollQueued = true;
    requestAnimationFrame(() => {
      scrollQueued = false;
      const hero = document.getElementById('top');
      if (!hero) return;
      const r = hero.getBoundingClientRect();
      const span = r.height - innerHeight;
      const p = span > 4 ? Math.min(1, Math.max(0, -r.top / span)) : 0;
      document.documentElement.style.setProperty('--hero-p', p.toFixed(4));
      hero.classList.toggle('is-condensed', p > 0.55);
    });
  }
  addEventListener('scroll', onScrub, { passive: true });
  addEventListener('resize', onScrub, { passive: true });
  document.addEventListener('astro:page-load', onScrub);

  // The wake-up is a MOMENT: the instant the kernel comes online, the eye
  // flares and a real event rides the rail from top to bottom — the pulse
  // is a genuine publish, so the choreography is the boot, not an actor
  // playing the boot.
  let woke = false;
  onKernel((status, bridge) => {
    if (status !== 'online' || !bridge || woke) return;
    woke = true;
    burst?.kick(16);
    void bridge.publish('site.v1.kernel.awake', JSON.stringify({ at: Date.now() }));
  });

  // The ornament is an instrument: real routed kernel events nudge the
  // wheels and light the accent planks. One module-lifetime poll of the
  // kernel's event counter; deltas become kicks.
  let lastRouted = -1;
  let polling = false;
  onKernel((status) => {
    if (status !== 'online' || polling) return;
    polling = true;
    setInterval(() => {
      const b = kernel();
      if (!b || !burst) return;
      const routed = Number(b.eventsRouted());
      if (lastRouted >= 0 && routed > lastRouted) burst.kick(routed - lastRouted);
      lastRouted = routed;
    }, 600);
  });
</script>
