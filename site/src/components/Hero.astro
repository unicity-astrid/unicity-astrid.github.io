---
/** Section 1 — hero. Pure type riding the spine; the claim badge is the
 *  first thing that docks onto the rail, and it is literal: the real kernel
 *  is booting in this tab. */
import CapsuleRing from './CapsuleRing.astro';
---

<header class="hero" id="top">
  <CapsuleRing />
  <div class="wrap hero-inner">
    <p class="eyebrow">Astrid</p>
    <h1 class="hero-title">
      Let your AI<br /><span class="gradient-text">actually do things</span>.
    </h1>
    <p class="hero-sub prose">
      Astrid is a home for AI agents and their tools. They can work for you,
      remember for you, and grow new abilities. They can never take more than
      you gave them, and you can always see exactly what they did.
    </p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="#dumb-kernel">See it running</a>
      <a class="btn" href="/book/">How it works</a>
    </div>
    <p class="hero-claim mono" id="hero-claim" data-state="booting" data-dock="kernel">
      <span class="hero-claim-dot" aria-hidden="true"></span>
      <span id="hero-claim-text">booting the real Astrid kernel in your tab…</span>
    </p>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: var(--s-7);
  }

  .hero-title {
    font-size: var(--step-6);
    font-weight: 700;
    margin-block: var(--s-3) var(--s-3);
    max-width: 12ch;
  }

  .hero-sub {
    font-size: var(--step-1);
    color: var(--text-dim);
    margin-bottom: var(--s-4);
  }

  .hero-ctas {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-5);
  }

  .hero-claim {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.5em 1em;
    border: 1px solid var(--line);
    border-radius: 8px;
    font-size: var(--step--1);
    color: var(--text-faint);
    background: var(--bg-raised);
  }

  .hero-claim-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-faint);
    flex: none;
  }

  .hero-claim[data-state='online'] {
    color: var(--text-dim);
    border-color: color-mix(in srgb, var(--bus) 35%, transparent);
  }

  .hero-claim[data-state='online'] .hero-claim-dot {
    background: var(--bus);
    box-shadow: 0 0 8px var(--bus);
  }
</style>

<script>
  import { onKernel, kernelStatus, kernel } from '../scripts/kernel';

  // Elements are re-created on every client-router visit; the module is not.
  // Re-apply the current kernel state to whatever hero is in the DOM.
  function apply(): void {
    const claim = document.getElementById('hero-claim');
    const text = document.getElementById('hero-claim-text');
    if (!claim || !text) return;
    const status = kernelStatus();
    const bridge = kernel();
    claim.dataset.state = status;
    if (status === 'online' && bridge) {
      text.textContent = `this page is running the real Astrid kernel · astrid-kernel@${bridge.kernelCommit()}`;
    } else if (status === 'offline') {
      text.textContent = 'kernel unavailable in this browser · showing static scenes';
    }
  }
  onKernel(apply);
  document.addEventListener('astro:page-load', apply);
</script>
