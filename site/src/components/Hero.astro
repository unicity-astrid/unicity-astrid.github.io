---
/** Section 1 — hero. The bus canvas idles behind the type; the claim badge
 *  below the CTAs is literal: the real kernel is booting in this tab. */
---

<header class="hero" id="top">
  <astrid-bus mode="hero" class="hero-bus" aria-hidden="true"></astrid-bus>
  <div class="wrap hero-inner">
    <p class="eyebrow">Astrid · a secure agent runtime</p>
    <h1 class="hero-title">
      An operating system<br />that <span class="gradient-text">agents extend</span>.
    </h1>
    <p class="hero-sub prose">
      Every ability is a capsule: sandboxed WebAssembly, signed capabilities, an
      audit chain grown byte by byte. Write a capsule, install it live, and the
      OS gains the skill. No forks. No trust required.
    </p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="#dumb-kernel">See it run</a>
      <a class="btn" href="/book/">Read the book</a>
    </div>
    <p class="hero-claim mono" id="hero-claim" data-state="booting">
      <span class="hero-claim-dot" aria-hidden="true"></span>
      <span id="hero-claim-text">booting the real Astrid kernel in your tab…</span>
    </p>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: center;
    overflow: hidden;
  }

  .hero-bus {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    display: block;
  }

  .hero-inner {
    position: relative;
    padding-block: var(--s-7);
  }

  .hero-title {
    font-size: var(--step-6);
    font-weight: 700;
    margin-block: var(--s-3) var(--s-3);
    max-width: 12ch;
  }

  .hero-sub {
    font-size: var(--step-1);
    color: var(--text-dim);
    margin-bottom: var(--s-4);
  }

  .hero-ctas {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-4);
  }

  .hero-claim {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    font-size: var(--step--1);
    color: var(--text-faint);
  }

  .hero-claim-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-faint);
    flex: none;
  }

  .hero-claim[data-state='online'] {
    color: var(--text-dim);
  }

  .hero-claim[data-state='online'] .hero-claim-dot {
    background: var(--bus);
    box-shadow: 0 0 8px var(--bus);
  }
</style>

<script>
  import '../scripts/bus-canvas';
  import { onKernel } from '../scripts/kernel';

  const claim = document.getElementById('hero-claim')!;
  const text = document.getElementById('hero-claim-text')!;
  onKernel((status, bridge) => {
    claim.dataset.state = status;
    if (status === 'online' && bridge) {
      text.textContent = `this page is running the real Astrid kernel · astrid-kernel@${bridge.kernelCommit()}`;
    } else if (status === 'offline') {
      text.textContent = 'kernel unavailable in this browser · showing static scenes';
    }
  });
</script>
