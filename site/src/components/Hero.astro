---
/** Section 1 — hero. Pure type riding the spine; the claim badge is the
 *  first thing that docks onto the rail, and it is literal: the real Astrid
 *  is waking up in this tab. The eye itself lives on the page-wide fixed
 *  layer (CapsuleRing, mounted by the page), not inside the hero. */
import unicityMark from '../assets/unicity-wordmark.svg?raw';
---

<header class="hero" id="top">
  <div class="hero-stage">
    <div class="wrap hero-inner">
    <p class="eyebrow hero-maker">
      Astrid <span class="hero-by">· a</span>
      <a
        href="https://www.unicity.ai"
        target="_blank"
        rel="noopener"
        aria-label="Unicity"
        set:html={unicityMark}
      />
      <span class="hero-by">project</span>
    </p>
    <h1 class="hero-title">
      Let your AI<br /><span class="gradient-text">actually do things</span>.
    </h1>
    <p class="hero-sub prose">
      Astrid is a home for AI agents and their tools. They can work for you,
      remember for you, and grow new abilities. They can never take more than
      you gave them, and you can always see exactly what they did.
    </p>
    <div class="hero-ctas">
      <a class="btn btn-primary" href="#dumb-kernel">See it running</a>
      <a class="btn" href="/book/">How it works</a>
    </div>
    <a class="hero-works mono" href="#bring">
      Works with <strong>Claude</strong> today · Codex, Hermes and OpenClaw soon
    </a>
    <p class="hero-claim mono" id="hero-claim" data-state="booting" data-dock="kernel">
      <span class="hero-claim-dot" aria-hidden="true"></span>
      <span id="hero-claim-text">Waking the real Astrid up in this tab…</span>
    </p>
    </div>
  </div>
</header>

<style>
  /* The hero is taller than the screen: the extra height is the scroll the
     visitor spends condensing the burst into the dot on the rail. The stage
     stays pinned while that happens; everything is a pure function of scroll
     position, so scrolling back up re-opens the eye exactly. */
  .hero {
    position: relative;
    height: 240svh;
  }

  .hero-stage {
    position: sticky;
    top: 0;
    height: 100svh;
    display: grid;
    align-items: center;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: var(--s-7);
    opacity: calc(1 - var(--hero-p, 0) * 1.6);
    translate: 0 calc(var(--hero-p, 0) * -5rem);
  }

  .hero.is-condensed .hero-inner {
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero {
      height: auto;
      min-height: 100svh;
    }

    .hero-inner {
      opacity: 1;
      translate: none;
    }
  }

  /* Phones: no pin at all. The hero copy is taller than the screen there,
     and a pinned stage turns scrolling into the condense scrub instead of
     revealing the buttons — content you can't reach. Same treatment the
     keys section gets: static flow, everything readable, the condense is a
     desktop luxury. Title drops a step so twelve characters fit. */
  @media (max-width: 640px) {
    .hero {
      height: auto;
      min-height: 100svh;
    }

    .hero-stage {
      position: static;
      height: auto;
      overflow: visible;
      align-items: start;
    }

    .hero-inner {
      opacity: 1;
      translate: none;
      padding-block: calc(var(--s-6) + 2.5rem) var(--s-7);
    }

    /* the scroll driver still stamps is-condensed; unpinned content must
       stay clickable regardless */
    .hero.is-condensed .hero-inner {
      pointer-events: auto;
    }

    .hero-title {
      font-size: var(--step-5);
    }
  }

  /* Load-in: each line arrives a beat after the last, once, on first
     paint. Scroll owns everything after that. */
  .hero-inner > * {
    animation: hero-rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-inner > .eyebrow { animation-delay: 0.05s; }
  .hero-inner > .hero-title { animation-delay: 0.14s; }
  .hero-inner > .hero-sub { animation-delay: 0.26s; }
  .hero-inner > .hero-ctas { animation-delay: 0.38s; }
  .hero-inner > .hero-works { animation-delay: 0.48s; }
  .hero-inner > .hero-claim { animation-delay: 0.6s; }

  @keyframes hero-rise {
    from {
      opacity: 0;
      translate: 0 1.4rem;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-inner > * {
      animation: none;
    }
  }

  /* Maker's mark: "Astrid · a Unicity project" — authorship, not a product
     line. Astrid is the upstream open project; Unicity is its creator and
     steward. Quiet, never competing with the headline. */
  .hero-maker {
    display: flex;
    align-items: center;
    gap: 0.6em;
  }

  .hero-by {
    color: var(--text-faint);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .hero-maker a {
    display: inline-flex;
    color: var(--text);
    opacity: 0.85;
    transition: opacity var(--t-fast) var(--ease-out);
  }

  .hero-maker a:hover {
    opacity: 1;
  }

  /* The wordmark's glyphs fill its viewBox edge to edge, so its height IS
     its cap height — size it just over the eyebrow's caps (~0.65em for the
     mono face); the scanline texture reads lighter than solid glyphs, so
     exact cap height would look undersized. */
  .hero-maker a :global(svg) {
    display: block;
    height: 0.8em;
    width: auto;
  }

  .hero-title {
    font-size: var(--step-6);
    font-weight: 700;
    margin-block: var(--s-3) var(--s-3);
    max-width: 12ch;
  }

  .hero-sub {
    font-size: var(--step-1);
    color: var(--text-dim);
    margin-bottom: var(--s-4);
  }

  .hero-ctas {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }

  /* The "do I have to switch?" answer, in the first viewport: no. Quiet
     strip, names on it, deep link to the full bring-yours section. */
  .hero-works {
    display: block;
    width: fit-content;
    font-size: var(--step--1);
    color: var(--text-faint);
    text-decoration: none;
    margin-bottom: var(--s-4);
    transition: color var(--t-fast) var(--ease-out);
  }

  .hero-works strong {
    color: var(--text-dim);
    font-weight: 600;
    transition: color var(--t-fast) var(--ease-out);
  }

  .hero-works:hover {
    color: var(--text-dim);
  }

  .hero-works:hover strong {
    color: var(--text);
  }

  .hero-claim {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.5em 1em;
    border: 1px solid var(--line);
    border-radius: 8px;
    font-size: var(--step--1);
    color: var(--text-faint);
    background: var(--bg-raised);
  }

  .hero-claim-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-faint);
    flex: none;
  }

  .hero-claim[data-state='online'] {
    color: var(--text-dim);
    border-color: color-mix(in srgb, var(--bus) 35%, transparent);
  }

  .hero-claim[data-state='online'] .hero-claim-dot {
    background: var(--bus);
    box-shadow: 0 0 8px var(--bus);
  }
</style>

<script>
  import { onKernel, kernelStatus, kernel } from '../scripts/kernel';

  // Elements are re-created on every client-router visit; the module is not.
  // Re-apply the current kernel state to whatever hero is in the DOM.
  function apply(): void {
    const claim = document.getElementById('hero-claim');
    const text = document.getElementById('hero-claim-text');
    if (!claim || !text) return;
    const status = kernelStatus();
    const bridge = kernel();
    claim.dataset.state = status;
    if (status === 'online' && bridge) {
      text.textContent = 'This page is static. Astrid is not — it’s running in this tab right now';
    } else if (status === 'offline') {
      text.textContent = 'Astrid can’t run in this browser · showing the story without the live demo';
    }
  }
  onKernel(apply);
  document.addEventListener('astro:page-load', apply);
</script>
