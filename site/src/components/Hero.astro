---
/** Section 1 — hero. Pure type riding the spine; the claim badge is the
 *  first thing that docks onto the rail, and it is literal: the real Astrid
 *  is waking up in this tab. The eye itself lives on the page-wide fixed
 *  layer (CapsuleRing, mounted by the page), not inside the hero. */
import unicityMark from '../assets/unicity-wordmark.svg?raw';
---

<header class="hero" id="top">
  <div class="hero-stage">
    <div class="wrap hero-inner">
    <p class="eyebrow hero-maker">
      Unicity Astrid OS <span class="hero-by">· by</span>
      <a
        href="https://www.unicity.ai"
        target="_blank"
        rel="noopener"
        aria-label="Unicity"
        set:html={unicityMark}
      />
      <span class="hero-by">project</span>
    </p>
    <h1 class="hero-title">
      A modular operating system<br />for <span class="gradient-text">AI agents</span>.
    </h1>
    <p class="hero-sub prose">
      Every ability is a sealed capsule: the model, the memory, the tools, the
      guards. Snap them together into an agent, swap any part later, and it can
      never take more than you gave it. Unicity Astrid OS slots in underneath the agent you
      already use.
    </p>
    <p class="hero-kicker">
      Let your AI actually do things, without handing over the keys.
    </p>

    <div class="hero-install" data-dock="install">
      <div class="hero-cmd-box">
        <code class="hero-cmd mono" id="hero-install-cmd"
          >curl -fsSL https://astridos.org/install.sh | sh</code
        >
        <button
          class="mono hero-copy"
          type="button"
          data-copy="curl -fsSL https://astridos.org/install.sh | sh"
          aria-label="Copy install command"
        >
          copy
        </button>
      </div>
      <p class="hero-install-note mono dim">
        Install or upgrade · detects Claude, Grok, Codex ·
        <a href="/start/">Homebrew, Cargo, plugins →</a>
      </p>
    </div>

    <div class="hero-ctas">
      <a class="btn btn-primary" href="/start/">Install options</a>
      <a class="btn" href="/how-it-works/">See how it works</a>
      <a class="btn" href="/build/">Build your agent</a>
    </div>
    <p class="hero-works mono">
      Plugins for <strong>Claude Code</strong>, <strong>Grok Build</strong>, and
      <strong>Codex</strong> — wired when those hosts are on the machine.
    </p>
    <p class="hero-claim mono" id="hero-claim" data-state="booting" data-dock="kernel">
      <span class="hero-claim-dot" aria-hidden="true"></span>
      <span id="hero-claim-text">Waking Unicity Astrid OS up in this tab…</span>
    </p>
    </div>
  </div>
</header>

<style>
  /* The hero is taller than the screen: the extra height is the scroll the
     visitor spends condensing the burst into the dot on the rail. The stage
     stays pinned while that happens; everything is a pure function of scroll
     position, so scrolling back up re-opens the eye exactly. */
  .hero {
    position: relative;
    height: 240svh;
  }

  .hero-stage {
    position: sticky;
    top: 0;
    height: 100svh;
    display: grid;
    align-items: center;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: var(--s-7);
    opacity: calc(1 - var(--hero-p, 0) * 1.6);
    translate: 0 calc(var(--hero-p, 0) * -5rem);
  }

  .hero.is-condensed .hero-inner {
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero {
      height: auto;
      min-height: 100svh;
    }

    .hero-inner {
      opacity: 1;
      translate: none;
    }
  }

  /* Phones: no pin at all. The hero copy is taller than the screen there,
     and a pinned stage turns scrolling into the condense scrub instead of
     revealing the buttons — content you can't reach. Same treatment the
     keys section gets: static flow, everything readable, the condense is a
     desktop luxury. Title drops a step so twelve characters fit. */
  @media (max-width: 640px) {
    .hero {
      height: auto;
      min-height: 100svh;
    }

    .hero-stage {
      position: static;
      height: auto;
      overflow: visible;
      align-items: start;
    }

    .hero-inner {
      opacity: 1;
      translate: none;
      padding-block: calc(var(--s-6) + 2.5rem) var(--s-7);
    }

    /* the scroll driver still stamps is-condensed; unpinned content must
       stay clickable regardless */
    .hero.is-condensed .hero-inner {
      pointer-events: auto;
    }

    .hero-title {
      font-size: var(--step-5);
    }
  }

  /* Load-in: each line arrives a beat after the last, once, on first
     paint. Scroll owns everything after that. */
  .hero-inner > * {
    animation: hero-rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-inner > .eyebrow { animation-delay: 0.05s; }
  .hero-inner > .hero-title { animation-delay: 0.14s; }
  .hero-inner > .hero-sub { animation-delay: 0.26s; }
  .hero-inner > .hero-kicker { animation-delay: 0.33s; }
  .hero-inner > .hero-install { animation-delay: 0.38s; }
  .hero-inner > .hero-ctas { animation-delay: 0.46s; }
  .hero-inner > .hero-works { animation-delay: 0.52s; }
  .hero-inner > .hero-claim { animation-delay: 0.6s; }

  @keyframes hero-rise {
    from {
      opacity: 0;
      translate: 0 1.4rem;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-inner > * {
      animation: none;
    }
  }

  /* Product mark: Unicity Astrid OS, created and stewarded by Unicity. */
  .hero-maker {
    display: flex;
    align-items: center;
    gap: 0.6em;
  }

  .hero-by {
    color: var(--text-faint);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .hero-maker a {
    display: inline-flex;
    color: var(--text);
    opacity: 0.85;
    transition: opacity var(--t-fast) var(--ease-out);
  }

  .hero-maker a:hover {
    opacity: 1;
  }

  /* The wordmark's glyphs fill its viewBox edge to edge, so its height IS
     its cap height — size it just over the eyebrow's caps (~0.65em for the
     mono face); the scanline texture reads lighter than solid glyphs, so
     exact cap height would look undersized. */
  .hero-maker a :global(svg) {
    display: block;
    height: 0.8em;
    width: auto;
  }

  .hero-title {
    font-size: var(--step-6);
    font-weight: 700;
    margin-block: var(--s-3) var(--s-3);
    max-width: 16ch;
  }

  .hero-sub {
    font-size: var(--step-1);
    color: var(--text-dim);
    margin-bottom: var(--s-2);
  }

  .hero-kicker {
    font-size: var(--step-0);
    color: var(--text);
    max-width: var(--prose-w);
    margin-bottom: var(--s-3);
  }

  .hero-install {
    max-width: min(40rem, 100%);
    margin-bottom: var(--s-4);
  }

  .hero-cmd-box {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--s-2);
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--bus) 28%, var(--line));
    background: color-mix(in srgb, var(--bg-raised) 88%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--bus) 8%, transparent);
  }

  .hero-cmd {
    flex: 1 1 14rem;
    font-size: clamp(0.78rem, 0.72rem + 0.3vw, 0.95rem);
    color: var(--bus);
    overflow-wrap: anywhere;
    line-height: 1.45;
    user-select: all;
  }

  .hero-copy {
    flex: none;
    background: none;
    border: 1px solid var(--line-bright);
    border-radius: 6px;
    color: var(--text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.45em 0.9em;
    cursor: pointer;
    transition:
      color var(--t-fast) var(--ease-out),
      border-color var(--t-fast) var(--ease-out),
      background var(--t-fast) var(--ease-out);
  }

  .hero-copy:hover {
    color: var(--text);
    border-color: var(--capsule);
  }

  .hero-copy[data-done] {
    color: var(--capsule);
    border-color: color-mix(in srgb, var(--capsule) 50%, transparent);
    background: color-mix(in srgb, var(--capsule) 12%, transparent);
  }

  .hero-install-note {
    margin-top: 0.55rem;
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .hero-install-note a {
    color: var(--text-dim);
  }

  .hero-install-note a:hover {
    color: var(--bus);
  }

  .hero-ctas {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin-bottom: var(--s-3);
  }

  .hero-works {
    display: block;
    width: fit-content;
    max-width: 42rem;
    font-size: var(--step--1);
    color: var(--text-faint);
    margin-bottom: var(--s-4);
    line-height: 1.5;
  }

  .hero-works strong {
    color: var(--text-dim);
    font-weight: 600;
  }

  .hero-claim {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.5em 1em;
    border: 1px solid var(--line);
    border-radius: 8px;
    font-size: var(--step--1);
    color: var(--text-faint);
    background: var(--bg-raised);
  }

  .hero-claim-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-faint);
    flex: none;
  }

  .hero-claim[data-state='online'] {
    color: var(--text-dim);
    border-color: color-mix(in srgb, var(--bus) 35%, transparent);
  }

  .hero-claim[data-state='online'] .hero-claim-dot {
    background: var(--bus);
    box-shadow: 0 0 8px var(--bus);
  }
</style>

<script>
  import { onKernel, kernelStatus, kernel } from '../scripts/kernel';

  // Elements are re-created on every client-router visit; the module is not.
  // Re-apply the current kernel state to whatever hero is in the DOM.
  function apply(): void {
    const claim = document.getElementById('hero-claim');
    const text = document.getElementById('hero-claim-text');
    if (!claim || !text) return;
    const status = kernelStatus();
    const bridge = kernel();
    claim.dataset.state = status;
    if (status === 'online' && bridge) {
      text.textContent = 'This page is static. Unicity Astrid OS is not — it’s running in this tab right now';
    } else if (status === 'offline') {
      text.textContent = 'Unicity Astrid OS can’t run in this browser · showing the story without the live demo';
    }
  }

  function wireCopy(): void {
    const hero = document.querySelector('.hero');
    if (!hero || (hero as HTMLElement).dataset.copyWired) return;
    (hero as HTMLElement).dataset.copyWired = '1';
    hero.querySelectorAll<HTMLButtonElement>('.hero-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.copy ?? '');
          btn.textContent = 'copied';
          btn.dataset.done = '1';
          setTimeout(() => {
            btn.textContent = 'copy';
            delete btn.dataset.done;
          }, 1400);
        } catch {
          /* command is user-selectable */
        }
      });
    });
  }

  onKernel(apply);
  wireCopy();
  document.addEventListener('astro:page-load', () => {
    apply();
    wireCopy();
  });
</script>
