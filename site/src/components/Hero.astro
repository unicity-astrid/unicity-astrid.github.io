---
/** Product promise, compatibility, and the free install path. The animated eye
 *  lives on the page-wide fixed layer mounted by the home page. */
import unicityMark from '../assets/unicity-wordmark.svg?raw';
import { AOS_RELEASE } from '../lib/release';
import AgentMark from './AgentMark.astro';
---

<header class="hero" id="top">
  <div class="hero-stage">
    <div class="wrap hero-inner">
    <p class="eyebrow hero-maker">
      Unicity AOS <span class="hero-by">· by</span>
      <a
        href="https://www.unicity.ai"
        target="_blank"
        rel="noopener"
        aria-label="Unicity"
        set:html={unicityMark}
      />
    </p>
    <p class="eyebrow hero-category">The operating system for AI agents</p>
    <h1 class="hero-title">
      You give it the goal.<br /><span class="gradient-text">It builds the missing ability.</span>
    </h1>
    <p class="hero-sub prose">
      Unicity AOS runs under the coding agent you already use. When it needs an
      ability it does not have, it builds one as an isolated extension, shows you
      exactly what it needs access to, asks for approval, installs it live, and
      keeps going.
    </p>

    <p class="hero-punch mono">No plugin hunting. No restart. No unrestricted machine access.</p>

    <div class="hero-agents" aria-label="Supported coding agents">
      <span class="mono hero-agents-label">Works with</span>
      <AgentMark agent="claude" />
      <AgentMark agent="grok" />
      <AgentMark agent="codex" />
    </div>

    <div class="hero-install" data-dock="install">
      <p class="mono hero-install-label">Free to use. One command.</p>
      <div class="hero-cmd-box">
        <code class="hero-cmd mono" id="hero-install-cmd">{AOS_RELEASE.installCommand}</code>
        {
          AOS_RELEASE.available && (
            <button
              class="mono hero-copy"
              type="button"
              data-copy={AOS_RELEASE.installCommand}
              aria-label="Copy install command"
            >
              copy
            </button>
          )
        }
      </div>
      <div class="hero-install-links mono">
        <a href="/how-it-works/#grow">Watch it extend itself →</a>
        <a href="/install.sh">Inspect install.sh</a>
      </div>
    </div>
    </div>
  </div>
</header>

<style>
  /* One short pinned beat gives the runtime eye room to condense. Copy remains
     fully visible through most of it and only leaves at the end. */
  .hero {
    position: relative;
    height: 180svh;
  }

  .hero-stage {
    position: sticky;
    top: 0;
    height: 100svh;
    display: grid;
    align-items: center;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: var(--s-7);
    translate: 0 var(--hero-copy-y, 0rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero {
      height: auto;
      min-height: 100svh;
    }

    .hero-inner {
      opacity: 1;
      translate: none;
    }
  }

  /* Phones: no pin at all. The hero copy is taller than the screen there,
     and a pinned stage turns scrolling into the condense scrub instead of
     revealing the buttons — content you can't reach. Same treatment the
     keys section gets: static flow, everything readable, the condense is a
     desktop luxury. Title drops a step so twelve characters fit. */
  @media (max-width: 640px) {
    .hero {
      height: auto;
      min-height: 100svh;
    }

    .hero-stage {
      position: static;
      height: auto;
      overflow: visible;
      align-items: start;
    }

    .hero-inner {
      opacity: 1;
      translate: none;
      padding-block: calc(var(--s-6) + 2.5rem) var(--s-7);
    }

    .hero-title {
      font-size: var(--step-4);
    }
  }

  /* Load-in: each line arrives a beat after the last, once, on first
     paint. Scroll owns everything after that. */
  .hero-inner > * {
    animation: hero-rise 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-inner > .eyebrow { animation-delay: 0.05s; }
  .hero-inner > .hero-category { animation-delay: 0.1s; }
  .hero-inner > .hero-title { animation-delay: 0.14s; }
  .hero-inner > .hero-sub { animation-delay: 0.26s; }
  .hero-inner > .hero-punch { animation-delay: 0.31s; }
  .hero-inner > .hero-agents { animation-delay: 0.36s; }
  .hero-inner > .hero-install { animation-delay: 0.44s; }

  @keyframes hero-rise {
    from {
      opacity: 0;
      translate: 0 1.4rem;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-inner > * {
      animation: none;
    }
  }

  /* Product mark: Unicity AOS, created and stewarded by Unicity. */
  .hero-maker {
    display: flex;
    align-items: center;
    gap: 0.6em;
  }

  .hero-by {
    color: var(--text-faint);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .hero-maker a {
    display: inline-flex;
    color: var(--text);
    opacity: 0.85;
    transition: opacity var(--t-fast) var(--ease-out);
  }

  .hero-maker a:hover {
    opacity: 1;
  }

  /* The wordmark's glyphs fill its viewBox edge to edge, so its height IS
     its cap height — size it just over the eyebrow's caps (~0.65em for the
     mono face); the scanline texture reads lighter than solid glyphs, so
     exact cap height would look undersized. */
  .hero-maker a :global(svg) {
    display: block;
    height: 0.8em;
    width: auto;
  }

  .hero-category {
    margin-top: var(--s-3);
    color: var(--capsule);
  }

  .hero-title {
    font-size: var(--step-5);
    font-weight: 700;
    margin-block: var(--s-3) var(--s-3);
    max-width: 21ch;
  }

  .hero-sub {
    font-size: var(--step-1);
    color: var(--text-dim);
    max-width: 45rem;
    margin-bottom: var(--s-2);
  }

  .hero-punch {
    color: var(--capsule);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
  }

  .hero-agents {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-3);
    width: fit-content;
    margin-top: var(--s-3);
    padding: 0.8rem 1rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--bg-raised) 82%, transparent);
  }

  .hero-agents-label {
    color: var(--text-faint);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-install {
    max-width: min(40rem, 100%);
    margin-block: var(--s-3) var(--s-4);
  }

  .hero-install-label {
    margin-bottom: var(--s-1);
    color: var(--text-dim);
    font-size: var(--step--1);
  }

  .hero-install-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-1) var(--s-3);
    margin-top: var(--s-2);
    font-size: var(--step--1);
  }

  .hero-install-links a {
    color: var(--text-dim);
  }

  .hero-install-links a:hover {
    color: var(--text);
  }

  .hero-cmd-box {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--s-2);
    padding: 0.85rem 1rem;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--bus) 28%, var(--line));
    background: color-mix(in srgb, var(--bg-raised) 88%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--bus) 8%, transparent);
  }

  .hero-cmd {
    flex: 1 1 14rem;
    font-size: clamp(0.78rem, 0.72rem + 0.3vw, 0.95rem);
    color: var(--bus);
    overflow-wrap: anywhere;
    line-height: 1.45;
    user-select: all;
  }

  .hero-copy {
    flex: none;
    background: none;
    border: 1px solid var(--line-bright);
    border-radius: 6px;
    color: var(--text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.45em 0.9em;
    cursor: pointer;
    transition:
      color var(--t-fast) var(--ease-out),
      border-color var(--t-fast) var(--ease-out),
      background var(--t-fast) var(--ease-out);
  }

  .hero-copy:hover {
    color: var(--text);
    border-color: var(--capsule);
  }

  .hero-copy[data-done] {
    color: var(--capsule);
    border-color: color-mix(in srgb, var(--capsule) 50%, transparent);
    background: color-mix(in srgb, var(--capsule) 12%, transparent);
  }

</style>

<script>
  async function copyText(value: string): Promise<void> {
    if (navigator.clipboard?.writeText) {
      try {
        await navigator.clipboard.writeText(value);
        return;
      } catch {
        // Fall through to the selection-based browser fallback.
      }
    }
    const field = document.createElement('textarea');
    field.value = value;
    field.setAttribute('readonly', '');
    field.style.position = 'fixed';
    field.style.opacity = '0';
    document.body.append(field);
    field.select();
    const copied = document.execCommand('copy');
    field.remove();
    if (!copied) throw new Error('copy was rejected');
  }

  function wireCopy(): void {
    const hero = document.querySelector('.hero');
    if (!hero || (hero as HTMLElement).dataset.copyWired) return;
    (hero as HTMLElement).dataset.copyWired = '1';
    hero.querySelectorAll<HTMLButtonElement>('.hero-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await copyText(btn.dataset.copy ?? '');
          btn.textContent = 'copied';
          btn.dataset.done = '1';
          setTimeout(() => {
            btn.textContent = 'copy';
            delete btn.dataset.done;
          }, 1400);
        } catch {
          /* command is user-selectable */
        }
      });
    });
  }

  wireCopy();
  document.addEventListener('astro:page-load', () => {
    wireCopy();
  });
</script>
