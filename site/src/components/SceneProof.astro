---
/** Section 6 — "Proof, not promises." The five-layer gate, compact, plus the
 *  live audit strip (real entries this page generated, once the kernel is up). */
const layers = [
  { name: 'Input screening', body: 'Everything arriving from outside is labelled untrusted before any AI reasons about it.' },
  { name: 'Permission checks', body: 'Every action is checked against what you actually granted. No permission, no action.' },
  { name: 'Tool-level gates', body: 'Each tool enforces its own rules on top, so one mistake cannot open everything.' },
  { name: 'The sandbox', body: 'Parts run in sealed boxes with no reach into your system. If something breaks, it breaks inside the box.' },
  { name: 'Approval and the record', body: 'You approve the irreversible, and a tamper-evident record remembers everything, permanently.' },
];
---

<section class="proof hairline-top" id="proof" data-scene>
  <div class="wrap proof-grid">
    <div class="prose">
      <p class="eyebrow">07 · the receipts</p>
      <h2 class="proof-title">Proof, not promises.</h2>
      <p>
        Most AI safety is a polite request written into a prompt. Astrid's is
        five separate locks, each of which must fail before anything is lost,
        and a permanent record that cannot quietly forget. You don't have to
        trust it; you can check it.
      </p>
      <p class="mono live-caption" id="proof-caption" hidden>
        the entries below are real: your clicks in the capability demo are in
        this chain
      </p>
    </div>
    <ol class="layers">
      {
        layers.map((l, i) => (
          <li class="layer" style={`--i:${i}`}>
            <span class="mono layer-n">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3>{l.name}</h3>
              <p class="dim">{l.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .proof {
    padding-block: var(--s-8);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: var(--s-6);
    align-items: start;
  }

  @media (max-width: 900px) {
    .proof-grid {
      grid-template-columns: 1fr;
    }
  }

  .proof-title {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  .layers {
    list-style: none;
    padding: 0;
    display: grid;
  }

  .layer {
    display: flex;
    gap: var(--s-3);
    padding: var(--s-3) var(--s-2);
    border-top: 1px solid var(--line);
  }

  .layer:last-child {
    border-bottom: 1px solid var(--line);
  }

  .layer-n {
    color: var(--audit);
    font-size: var(--step--1);
    padding-top: 0.35em;
  }

  .layer h3 {
    font-size: var(--step-1);
    margin-bottom: 0.25em;
  }

  .layer .dim {
    font-size: var(--step--1);
  }

  .live-caption {
    margin-top: var(--s-3);
    font-size: var(--step--1);
    color: var(--audit);
  }
</style>

<script>
  import { onKernel } from '../scripts/kernel';

  const caption = document.getElementById('proof-caption')!;
  onKernel((status, bridge) => {
    // only claim the chain is on the page once the audit read surface exists
    caption.hidden = status !== 'online' || !bridge?.auditTail;
  });
</script>
