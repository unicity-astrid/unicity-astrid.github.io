---
/** Section 7 — the receipt. The page's closing argument is a till-style
 *  printout of what the runtime engine in this tab actually did while the visitor was
 *  here: real message counts, their guard blocks, their permission
 *  decisions. The five-lock gate rides along as one compact strip — the
 *  receipt is the proof; the locks are the mechanism. Numbers only move
 *  when the visitor makes them move; a short receipt is an honest one. */
const locks = [
  'Input labelled untrusted',
  'Permission checks',
  'Tool-level gates',
  'The sandbox',
  'Approval + a runtime-local record',
];
---

<section class="proof hairline-top" id="proof" data-scene>
  <div class="wrap proof-grid">
    <div class="prose">
      <p class="eyebrow">08 · the receipt</p>
      <h2 class="proof-title">Proof, not promises.</h2>
      <p>
        Most AI safety is a polite request written into a prompt. Unicity AOS builds on
        separate runtime controls: labelled input, capability checks, tool gates,
        sandboxing, approvals, and audit records. The browser engine below is
        Astrid Runtime, not the full AOS product. It records only this tab's local
        runtime activity; Unicity Audit on the blockchain is a separate integration.
      </p>
      <p class="mono locks-strip dim">
        {locks.join(' · ')}
      </p>
    </div>

    <div class="card receipt mono">
      <p class="receipt-head">ASTRID RUNTIME · THIS TAB · LIVE</p>
      <dl class="receipt-rows">
        <div><dt>Messages carried</dt><dd id="rc-events">0</dd></div>
        <div><dt>Stopped by the guard</dt><dd id="rc-blocked">0</dd></div>
        <div><dt>Echo replies delivered</dt><dd id="rc-replies">0</dd></div>
        <div><dt>Permissions granted to you</dt><dd id="rc-granted">0</dd></div>
        <div class="receipt-deny"><dt>Permissions denied to you</dt><dd id="rc-denied">0</dd></div>
      </dl>
      <p class="receipt-note dim" id="rc-note">
        Short receipt? You haven't touched the live controls yet. Nothing here moves
        unless you move it.
      </p>
      <p class="receipt-foot">LOCAL RUNTIME RECORD</p>
    </div>
  </div>
</section>

<style>
  .proof {
    padding-block: var(--s-8);
  }

  .proof-grid {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
    gap: var(--s-6);
    align-items: start;
  }

  @media (max-width: 900px) {
    .proof-grid {
      grid-template-columns: 1fr;
    }
  }

  .proof-title {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  .locks-strip {
    margin-top: var(--s-3);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 2;
  }

  /* the till receipt: dashed edges, tabular numerals, no decoration */
  .receipt {
    max-width: 26rem;
    justify-self: end;
    width: 100%;
    padding: var(--s-3) var(--s-3) var(--s-2);
    border-style: dashed;
    font-size: var(--step--1);
  }

  @media (max-width: 900px) {
    .receipt {
      justify-self: start;
    }
  }

  .receipt-head {
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    color: var(--text-dim);
    border-bottom: 1px dashed var(--line);
    padding-bottom: var(--s-1);
    margin-bottom: var(--s-2);
  }

  .receipt-rows {
    display: grid;
    gap: 0.45em;
    margin-bottom: var(--s-2);
  }

  .receipt-rows div {
    display: flex;
    justify-content: space-between;
    gap: var(--s-2);
  }

  .receipt-rows dt {
    color: var(--text-dim);
  }

  .receipt-rows dd {
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }

  .receipt-deny dd {
    color: var(--deny);
  }

  .receipt-note {
    font-size: 0.72rem;
    line-height: 1.5;
    margin-bottom: var(--s-2);
  }

  .receipt-foot {
    text-align: center;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--text-faint);
    border-top: 1px dashed var(--line);
    padding-top: var(--s-1);
  }
</style>

<script>
  import { onKernel, kernel } from '../scripts/kernel';
  import { onTally, currentTally, bump } from '../scripts/site-tally';

  // Real sources only: the kernel's own event counter, the guard/echo bus
  // topics, and the permission demo's store decisions. Elements are looked
  // up per render because navigations re-create them; module state (the
  // subscriptions, the tally) survives.
  let subscribed = false;
  let ticking = false;

  function render(): void {
    const t = currentTally();
    const set = (id: string, v: number | string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(v);
    };
    set('rc-blocked', t.blocked);
    set('rc-replies', t.replies);
    set('rc-granted', t.granted);
    set('rc-denied', t.denied);
    const note = document.getElementById('rc-note');
    if (note) note.hidden = t.blocked + t.replies + t.granted + t.denied > 0;
  }

  onKernel((status, bridge) => {
    if (status !== 'online' || !bridge) return;
    if (!subscribed) {
      subscribed = true;
      bridge.subscribe('site.v1.guard.blocked', () => bump('blocked'));
      bridge.subscribe('site.v1.echo.reply', () => bump('replies'));
    }
    if (!ticking) {
      ticking = true;
      setInterval(() => {
        const b = kernel();
        const el = document.getElementById('rc-events');
        if (b && el) el.textContent = String(b.eventsRouted());
      }, 1500);
    }
  });

  onTally(render);
  document.addEventListener('astro:page-load', render);
</script>
