---
/**
 * The agent pill: an oval input docked above the rail, bottom of viewport.
 * Two honest modes, labelled:
 *  - docs lens (default): finds developer-guide chapters for what you typed and for
 *    where you are on the page. Search, not intelligence; says so.
 *  - local agent (opt-in): WebLLM in your tab, weights downloaded only after
 *    a click that states the size. Answers grounded in the developer guide, status
 *    streamed over the real bus.
 */
---

<div class="pill-wrap" id="pill-wrap">
  <div class="pill-panel card" id="pill-panel" role="region" aria-label="Developer guide assistant" hidden>
    <div class="pill-status mono" id="pill-status" role="status" aria-live="polite" hidden></div>
    <div class="pill-results" id="pill-results"></div>
    <div class="pill-progress" id="pill-progress" hidden>
      <div class="pill-progress-bar" id="pill-progress-bar"></div>
    </div>
    <p class="pill-mode mono" id="pill-mode">
      Docs lens: this finds chapters, it does not think. The button on the
      right turns on a real AI that runs entirely in your tab.
    </p>
    <p class="pill-consent mono" id="pill-consent" hidden>
      The agent runs entirely in your tab (WebGPU) and downloads
      <span id="pill-size">~450&nbsp;MB</span> of model weights, once. Your
      browser caches them, and you can remove them just as easily (Under the
      hood panel, top right). Nothing you type ever leaves this page.
      <button class="pill-enable mono" id="pill-confirm" type="button">Download and run</button>
      <button class="pill-enable mono" id="pill-alt" type="button">Use your own model…</button>
      <button class="pill-enable mono" id="pill-cancel" type="button">Cancel</button>
    </p>
    <div class="pill-consent mono" id="pill-endpoint" hidden>
      <p class="pill-ep-note">
        Bring a model you already have. Keys and URLs live in this tab's
        memory only, are sent nowhere but the provider you pick, and are
        never saved.
      </p>
      <div id="pill-ep-found" hidden></div>
      <div class="pill-ep-row">
        <button class="pill-enable mono" id="pill-ep-anthropic" type="button">Anthropic key…</button>
        <button class="pill-enable mono" id="pill-ep-openai" type="button">OpenAI key…</button>
        <button class="pill-enable mono" id="pill-ep-custom" type="button">Custom URL…</button>
        <button class="pill-enable mono" id="pill-ep-cancel" type="button">Back</button>
      </div>
      <div id="pill-ep-manual" hidden>
        <input class="pill-ep mono" id="pill-ep-url" type="url" aria-label="Model endpoint URL" placeholder="http://localhost:11434/v1" autocomplete="off" spellcheck="false" />
        <input class="pill-ep mono" id="pill-ep-key" type="password" aria-label="Model API key" placeholder="API key (optional)" autocomplete="off" />
        <input class="pill-ep mono" id="pill-ep-model" type="text" aria-label="Model name" placeholder="Model name (optional)" autocomplete="off" spellcheck="false" />
        <div>
          <button class="pill-enable mono" id="pill-ep-connect" type="button">Connect</button>
        </div>
      </div>
    </div>
    <div class="pill-link mono" id="pill-link-row">
      <button class="pill-enable mono" id="pill-phone" type="button">Use your phone →</button>
      <div id="pill-link-open" hidden>
        <canvas id="pill-qr" width="0" height="0"></canvas>
        <p class="pill-link-note dim" id="pill-link-status"></p>
      </div>
    </div>
  </div>
  <form class="pill-form" id="pill-form">
    <span class="pill-dot" id="pill-dot" data-state="lens" aria-hidden="true"></span>
    <label class="visually-hidden" for="pill-input">Search the developer guide or ask the local agent</label>
    <input
      id="pill-input"
      class="pill-input mono"
      type="text"
      placeholder="Search the developer guide…"
      autocomplete="off"
      maxlength="200"
    />
    <button class="pill-mic" id="pill-mic" type="button" hidden aria-label="Ask by voice" title="Ask by voice">
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
        <rect x="9" y="3" width="6" height="11" rx="3" fill="currentColor" />
        <path d="M6 11a6 6 0 0 0 12 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <line x1="12" y1="17" x2="12" y2="21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
    </button>
    <button class="pill-ai mono" id="pill-enable" type="button" title="Run a local AI in this tab">
      ✦ Enable AI
    </button>
    <button class="pill-send mono" type="submit" aria-label="Ask">→</button>
  </form>
</div>

<style>
  .pill-wrap {
    position: fixed;
    /* --pill-lift keeps the pill resting above the footer instead of
       covering the maker's line; the script measures the overlap. */
    bottom: calc(var(--s-3) + env(safe-area-inset-bottom, 0px) + var(--pill-lift, 0px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 90;
    width: min(32rem, calc(100vw - 2 * var(--s-2)));
    display: grid;
    gap: 0.5rem;
    /* Plays as the pill arrives on page load. */
    animation: pill-arrive 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes pill-arrive {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(2.2rem) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1);
    }
  }

  .pill-form {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35rem 0.5rem 0.35rem 1rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 12px 40px -18px rgb(0 0 0 / 0.55);
    transition:
      border-color 0.25s ease,
      box-shadow 0.35s ease,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .pill-form:focus-within {
    border-color: var(--bus);
    box-shadow: 0 16px 48px -16px rgb(0 0 0 / 0.6);
    transform: translateY(-2px);
  }

  .pill-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-faint);
    flex: none;
  }

  .pill-dot[data-state='ready'] {
    background: var(--grant);
  }

  .pill-dot[data-state='loading'],
  .pill-dot[data-state='thinking'] {
    background: var(--bus);
    animation: pill-blink 1s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .pill-wrap,
    .pill-panel {
      animation: none;
    }
  }

  @keyframes pill-blink {
    50% { opacity: 0.35; }
  }

  .pill-input {
    flex: 1;
    background: none;
    border: none;
    color: var(--text);
    font-size: var(--step--1);
    outline: none;
  }

  .pill-input::placeholder {
    color: var(--text-faint);
  }

  .pill-ai {
    flex: none;
    background: color-mix(in srgb, var(--capsule) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--capsule) 45%, transparent);
    border-radius: 999px;
    color: var(--capsule);
    font: inherit;
    font-size: 0.72rem;
    padding: 0.35em 0.8em;
    cursor: pointer;
    white-space: nowrap;
  }

  .pill-ai,
  .pill-send,
  .pill-enable {
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .pill-ai:hover {
    border-color: var(--capsule);
    transform: translateY(-1px);
  }

  .pill-ai:active,
  .pill-send:active {
    transform: scale(0.94);
  }

  .pill-ai[data-on='true'] {
    color: var(--grant);
    background: color-mix(in srgb, var(--grant) 12%, transparent);
    border-color: color-mix(in srgb, var(--grant) 40%, transparent);
    cursor: default;
  }

  .pill-progress {
    height: 3px;
    border-radius: 2px;
    background: var(--line);
    overflow: hidden;
    margin-top: var(--s-2);
  }

  .pill-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--capsule);
    transition: width 0.3s ease;
  }

  .pill-send {
    background: none;
    border: 1px solid var(--line);
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    color: var(--text-dim);
    cursor: pointer;
  }

  .pill-send:hover {
    color: var(--text);
    border-color: var(--bus);
  }

  .pill-status {
    font-size: 0.72rem;
    color: var(--bus);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.5em;
    margin-bottom: var(--s-2);
  }

  .pill-panel {
    max-height: 40vh;
    overflow-y: auto;
    padding: var(--s-2);
    transform-origin: bottom center;
    /* Replays on every unhide (display: none -> block restarts it). */
    animation: panel-rise 0.42s cubic-bezier(0.22, 1, 0.36, 1) both;
    box-shadow: 0 24px 70px -30px rgb(0 0 0 / 0.6);
  }

  @keyframes panel-rise {
    from {
      opacity: 0;
      transform: translateY(0.9rem) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .pill-results {
    display: grid;
    gap: 0.5rem;
    font-size: var(--step--1);
  }

  .pill-results :global(a) {
    display: block;
    padding: 0.5em 0.7em;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
  }

  .pill-results :global(a:hover) {
    border-color: var(--capsule);
    text-decoration: none;
  }

  .pill-results :global(a .t) {
    color: var(--capsule);
    display: block;
  }

  .pill-results :global(a .e) {
    color: var(--text-faint);
    font-size: 0.85em;
  }

  .pill-results :global(.answer) {
    white-space: pre-wrap;
    color: var(--text);
    line-height: 1.6;
  }

  .pill-results :global(.turn-you) {
    color: var(--text-dim);
    font-size: 0.78rem;
    border-top: 1px solid var(--line);
    padding-top: 0.5em;
  }

  .pill-results :global(.turn-you:first-child) {
    border-top: none;
    padding-top: 0;
  }

  .pill-results :global(.ctx) {
    color: var(--text-faint);
    font-size: 0.8em;
  }

  /* Grounding refs are inline links, not the block chapter cards above. */
  .pill-results :global(.ctx a.ref) {
    display: inline;
    padding: 0;
    border: none;
    border-radius: 0;
    color: var(--capsule);
  }

  .pill-results :global(.ctx a.ref:hover) {
    text-decoration: underline;
  }

  .pill-mode,
  .pill-consent {
    margin-top: var(--s-2);
    font-size: 0.72rem;
    color: var(--text-faint);
    line-height: 1.6;
  }

  .pill-ep-note {
    margin-bottom: var(--s-1);
  }

  .pill-ep {
    display: block;
    width: 100%;
    margin-bottom: 0.4rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
    font-size: 0.72rem;
    padding: 0.5em 0.8em;
  }

  .pill-ep:focus-visible {
    outline: none;
    border-color: var(--bus);
  }

  .pill-ep-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: var(--s-1);
  }

  /* "LM Studio is running — connect it?" detection card */
  :global(.pill-ep-card) {
    display: grid;
    gap: 0.4rem;
    padding: 0.6rem 0.8rem;
    margin-bottom: 0.4rem;
    border: 1px solid color-mix(in srgb, var(--bus) 40%, var(--line));
    border-radius: 10px;
    background: color-mix(in srgb, var(--bus) 6%, transparent);
  }

  :global(.pill-ep-card .pill-ep-card-row) {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  :global(.pill-ep-card select) {
    flex: 1;
    min-width: 0;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--text);
    font: inherit;
    font-size: 0.72rem;
    padding: 0.4em 0.6em;
  }

  .pill-enable {
    background: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--capsule);
    font: inherit;
    padding: 0.1em 0.7em;
    cursor: pointer;
    margin-left: 0.4em;
  }

  .pill-enable:hover {
    border-color: var(--capsule);
  }

  /* the mic: voice in, when the browser can hear */
  .pill-mic {
    flex: none;
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: none;
    border: 1px solid var(--line);
    color: var(--text-dim);
    cursor: pointer;
    transition:
      color var(--t-fast) var(--ease-out),
      border-color var(--t-fast) var(--ease-out);
  }

  .pill-mic:hover {
    color: var(--text);
    border-color: var(--line-bright);
  }

  .pill-mic[data-on='true'] {
    color: var(--deny);
    border-color: color-mix(in srgb, var(--deny) 55%, transparent);
    animation: mic-pulse 1.5s ease-in-out infinite;
  }

  @keyframes mic-pulse {
    50% {
      box-shadow: 0 0 0 5px color-mix(in srgb, var(--deny) 16%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pill-mic[data-on='true'] {
      animation: none;
    }
  }

  /* streamed characters fade in rather than snap-appearing */
  .pill-results :global(.answer .roll) {
    animation: roll-in 0.3s ease-out both;
  }

  @keyframes roll-in {
    from {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pill-results :global(.answer .roll) {
      animation: none;
    }
  }

  /* the phone uplink: QR + status live in the panel's footer */
  .pill-link {
    margin-top: var(--s-2);
    border-top: 1px solid var(--line);
    padding-top: var(--s-2);
    font-size: 0.72rem;
  }

  #pill-qr {
    display: block;
    margin: var(--s-2) auto;
    background: #fff;
    padding: 8px;
    border-radius: 8px;
  }

  /* display:block above would defeat the hidden attribute once linked */
  #pill-qr[hidden] {
    display: none;
  }

  .pill-link-note {
    font-size: 0.72rem;
    line-height: 1.5;
    text-align: center;
  }

  .pill-link-note[data-ok] {
    color: var(--bus);
  }

  @media (max-width: 640px) {
    .pill-wrap {
      width: calc(100vw - 2 * var(--s-2));
    }

    /* a phone doesn't pair with itself; the QR row is desktop furniture */
    .pill-link {
      display: none;
    }
  }
</style>

<script>
  import { onKernel, type AstridBridge } from '../scripts/kernel';
  import { searchGuide, queryForSection, type Chapter } from '../scripts/guide-lens';
  import { startNavContext, currentSection } from '../scripts/nav-context';
  import {
    enableAgent,
    askAgent,
    agentState,
    webGpuAvailable,
    pickModelSize,
    connectEndpoint,
  } from '../scripts/local-agent';
  import { fleetReady, fleetAsk } from '../scripts/fleet-host';

  const $ = (id: string) => document.getElementById(id)!;
  const wrap = $('pill-wrap');
  const panel = $('pill-panel');
  const results = $('pill-results');
  const statusLine = $('pill-status');
  const dot = $('pill-dot');
  const input = $('pill-input') as HTMLInputElement;
  const mode = $('pill-mode');
  const consent = $('pill-consent');
  const OPTIN_KEY = 'aos-agent-optin';
  const LEGACY_OPTIN_KEY = 'astrid-agent-optin';

  let bridge: AstridBridge | null = null;

  // The pill yields to the footer: as the page bottom scrolls into view the
  // pill rides up and rests above it, so the maker's line stays readable.
  // Measured per frame against whatever footer the current page has (the
  // client router swaps pages under a persistent pill).
  let liftRaf = 0;
  const updateLift = () => {
    liftRaf = 0;
    const foot = document.querySelector('footer.footer');
    let lift = 0;
    if (foot) {
      lift = Math.max(0, Math.round(window.innerHeight - foot.getBoundingClientRect().top));
    }
    wrap.style.setProperty('--pill-lift', `${lift}px`);
  };
  const queueLift = () => {
    if (!liftRaf) liftRaf = requestAnimationFrame(updateLift);
  };
  window.addEventListener('scroll', queueLift, { passive: true });
  window.addEventListener('resize', queueLift, { passive: true });
  document.addEventListener('astro:page-load', queueLift);
  queueLift();

  onKernel((status, b) => {
    if (status !== 'online' || !b) return;
    bridge = b;
    startNavContext(b);
    // Prior opt-in: bring the agent straight back from the weight cache.
    const optedIn = localStorage.getItem(OPTIN_KEY) === '1' || localStorage.getItem(LEGACY_OPTIN_KEY) === '1';
    if (optedIn) {
      localStorage.setItem(OPTIN_KEY, '1');
      localStorage.removeItem(LEGACY_OPTIN_KEY);
    }
    if (optedIn && webGpuAvailable() && agentState() === 'off') {
      startEngine(true);
    }
    // The pill renders agent status from the same bus events everyone else
    // sees; the status line IS the event stream.
    b.subscribe('site.agent.v1.status', (_t, json) => {
      try {
        const { state, detail } = JSON.parse(json) as { state: string; detail: string };
        dot.dataset.state = state === 'off' || state === 'unsupported' ? 'lens' : state;
        statusLine.hidden = false;
        statusLine.textContent = `agent · ${state}${detail ? ` · ${detail}` : ''}`;
      } catch {
        /* keep the previous status */
      }
    });
  });

  function showPanel(): void {
    panel.hidden = false;
  }

  // Other sections can summon the resident: the pill is fixed (always on
  // screen), so summoning is just focusing the input — the focus handler
  // below does the right thing (transcript if one exists, else the lens).
  document.addEventListener('astrid:pill-open', () => {
    input.focus();
  });

  function renderChapters(chapters: Chapter[], heading?: string): void {
    results.innerHTML = '';
    if (heading) {
      const p = document.createElement('p');
      p.className = 'ctx mono';
      p.textContent = heading;
      results.append(p);
    }
    if (!chapters.length) {
      const p = document.createElement('p');
      p.className = 'ctx mono';
      p.textContent = 'Nothing in the developer guide matched that.';
      results.append(p);
    }
    for (const c of chapters) {
      const a = document.createElement('a');
      a.href = c.url;
      const t = document.createElement('span');
      t.className = 't';
      t.textContent = c.title;
      const e = document.createElement('span');
      e.className = 'e';
      e.textContent = `${c.excerpt}…`;
      a.append(t, e);
      results.append(a);
    }
  }

  // Focus reopens what you were doing: a conversation in progress comes
  // back (it survives navigation; the click-away that closed it should not
  // cost the thread). Otherwise, the contextual lens: where you are -> the
  // guide chapters behind it.
  input.addEventListener('focus', () => {
    if (!panel.hidden || input.value) return;
    if (transcript.length) {
      showPanel();
      renderTranscript(true);
      return;
    }
    const section = currentSection();
    if (!section) return;
    void searchGuide(queryForSection(section), 3).then((chapters) => {
      if (input.value) return; // they started typing; don't stomp
      showPanel();
      renderChapters(chapters, `behind this section (${section}):`);
    });
  });

  // Opt-in is remembered: once you have enabled the agent, a hard reload
  // restores it straight from the browser's weight cache without re-asking.
  const chip = $('pill-enable');
  const progressWrap = $('pill-progress');
  const progressBar = $('pill-progress-bar');

  function startEngine(restoring: boolean): void {
    if (!bridge) return;
    consent.hidden = true;
    showPanel();
    progressWrap.hidden = false;
    mode.textContent = restoring
      ? 'Restoring the model from your browser cache…'
      : 'Starting download…';
    mode.hidden = false;
    chip.textContent = '✦ Loading…';
    void enableAgent(bridge, (text, progress) => {
      mode.textContent = text;
      progressBar.style.width = `${Math.round(progress * 100)}%`;
    }).then((ok) => {
      progressWrap.hidden = true;
      if (ok) {
        localStorage.setItem(OPTIN_KEY, '1');
        chip.dataset.on = 'true';
        chip.textContent = '✦ AI on';
        input.placeholder = 'Ask the agent…';
        mode.textContent =
          'Local agent running in your tab. Answers are grounded in the developer guide, and it travels with you across pages.';
      } else {
        chip.textContent = '✦ Enable AI';
        mode.textContent = 'Model load failed; the docs lens still works.';
      }
    });
  }

  const epForm = $('pill-endpoint');
  const epFound = $('pill-ep-found');
  const epManual = $('pill-ep-manual');
  const epUrl = $('pill-ep-url') as HTMLInputElement;
  const epKey = $('pill-ep-key') as HTMLInputElement;
  const epModel = $('pill-ep-model') as HTMLInputElement;
  let epFlavor: 'openai' | 'anthropic' = 'openai';
  let epLabel: string | undefined;

  function connectBrought(e: Parameters<typeof connectEndpoint>[1], from: string): void {
    if (!bridge) {
      // Never fail silently: the brought model is fine, it's the OS in this
      // tab that isn't up (still booting, or this browser can't run it).
      mode.hidden = false;
      mode.textContent = `Found ${from}, but the OS in this tab isn't running yet, so there's nothing to connect it to. Wait for the status pill to go live and try again.`;
      return;
    }
    mode.hidden = false;
    mode.textContent = `Checking ${from}…`;
    connectEndpoint(bridge, e).then(
      () => {
        epForm.hidden = true;
        chip.dataset.on = 'true';
        chip.textContent = '✦ AI on';
        input.placeholder = 'Ask the agent…';
        mode.textContent = `${from} is connected. The key (if any) lives only in this tab’s memory and is sent only to that provider.`;
      },
      (err: unknown) => {
        mode.textContent = `Could not reach ${from}: ${err instanceof Error ? err.message : err}. Check the URL (https or localhost) and any CORS setting on your server.`;
      },
    );
  }

  // ---- "looks like you already run a model" — the llm-connect scan ----
  // Probes the well-known local servers (LM Studio, Ollama, llama.cpp,
  // Jan). A hit renders a one-click card with a model picker; a miss
  // renders nothing. Detection can't see servers with CORS disabled,
  // which is why the manual paths stay.
  let scanned = false;
  function scanLocal(): void {
    if (scanned) return;
    scanned = true;
    void import('../scripts/llm-connect').then(({ detectLocalProviders }) =>
      detectLocalProviders().then((list) => {
        if (!list.length) return;
        epFound.innerHTML = '';
        for (const p of list) {
          const card = document.createElement('div');
          card.className = 'pill-ep-card';
          const line = document.createElement('span');
          line.textContent = `Looks like ${p.label} is running on this machine. Connect it to this site?`;
          const row = document.createElement('div');
          row.className = 'pill-ep-card-row';
          const sel = document.createElement('select');
          sel.setAttribute('aria-label', `${p.label} model`);
          for (const m of p.models) {
            const opt = document.createElement('option');
            opt.value = m;
            opt.textContent = m + (m === p.loaded ? ' · loaded' : '');
            sel.append(opt);
          }
          if (p.loaded) sel.value = p.loaded;
          const go = document.createElement('button');
          go.type = 'button';
          go.className = 'pill-enable mono';
          go.textContent = 'Connect →';
          go.addEventListener('click', () => {
            connectBrought(
              { base: p.base, model: sel.value, flavor: p.flavor, label: p.label },
              p.label,
            );
          });
          row.append(sel, go);
          card.append(line, row);
          epFound.append(card);
        }
        epFound.hidden = false;
      }),
    );
  }

  function openEndpointForm(): void {
    epForm.hidden = false;
    scanLocal();
  }

  chip.addEventListener('click', () => {
    const s = agentState();
    if (s === 'ready' || s === 'loading') return;
    showPanel();
    if (!bridge) {
      mode.hidden = false;
      mode.textContent =
        'Developer guide search is ready. The local agent needs the in-browser runtime, which is still starting or unavailable in this browser.';
      return;
    }
    mode.hidden = true;
    if (!webGpuAvailable()) {
      // no GPU for a downloaded model, but a brought model lives elsewhere:
      // the endpoint path stays fully available
      openEndpointForm();
      return;
    }
    // Phones don't get the download at all: a 1B model's working set sits
    // above iOS Safari's per-tab memory ceiling (field-tested: the tab
    // dies mid-load), and a model small enough to survive isn't worth the
    // download. A brought key runs on the provider, so that path stays.
    if (/Android|iPhone|iPad|Mobi/i.test(navigator.userAgent)) {
      mode.hidden = false;
      mode.textContent =
        'On-device AI needs desktop-class memory, and phone browsers kill the tab mid-load. Bring your own key below; it runs on the provider, not the phone. Or open this page on a computer.';
      openEndpointForm();
      return;
    }
    void pickModelSize().then((size) => {
      const el = document.getElementById('pill-size');
      if (el) el.textContent = size;
    });
    consent.hidden = false;
  });
  $('pill-cancel').addEventListener('click', () => {
    consent.hidden = true;
    mode.hidden = false;
  });
  $('pill-confirm').addEventListener('click', () => startEngine(false));

  // ---- bring-your-own-model ----
  $('pill-alt').addEventListener('click', () => {
    consent.hidden = true;
    openEndpointForm();
  });
  $('pill-ep-cancel').addEventListener('click', () => {
    epForm.hidden = true;
    epManual.hidden = true;
    if (webGpuAvailable()) consent.hidden = false;
    else mode.hidden = false;
  });
  // Cloud presets prefill the manual form; the visitor only types a key.
  $('pill-ep-anthropic').addEventListener('click', () => {
    epFlavor = 'anthropic';
    epLabel = 'Anthropic';
    epUrl.value = 'https://api.anthropic.com';
    epKey.placeholder = 'sk-ant-… (required)';
    epModel.value = '';
    epModel.placeholder = 'claude-haiku-4-5';
    epManual.hidden = false;
    epKey.focus();
  });
  $('pill-ep-openai').addEventListener('click', () => {
    epFlavor = 'openai';
    epLabel = 'OpenAI';
    epUrl.value = 'https://api.openai.com/v1';
    epKey.placeholder = 'sk-… (required)';
    epModel.value = '';
    epModel.placeholder = 'gpt-5-mini';
    epManual.hidden = false;
    epKey.focus();
  });
  $('pill-ep-custom').addEventListener('click', () => {
    epFlavor = 'openai';
    epLabel = undefined;
    epUrl.value = '';
    epKey.placeholder = 'API key (optional)';
    epModel.placeholder = 'model name (optional)';
    epManual.hidden = false;
    epUrl.focus();
  });
  $('pill-ep-connect').addEventListener('click', () => {
    const base = epUrl.value.trim();
    if (!base) return;
    const key = epKey.value.trim() || undefined;
    const model =
      epModel.value.trim() ||
      (epFlavor === 'anthropic' ? 'claude-haiku-4-5' : epLabel === 'OpenAI' ? 'gpt-5-mini' : undefined);
    connectBrought(
      { base, key, model, flavor: epFlavor, label: epLabel },
      epLabel ?? 'your endpoint',
    );
  });

  // The conversation is a session, not a series of one-shots: turns live in
  // module state (they survive navigation, since the pill and this module
  // persist) and prior turns feed the model as context.
  interface Turn {
    role: 'user' | 'assistant';
    text: string;
    refs?: { slug: string; title: string }[];
  }
  const transcript: Turn[] = [];

  // ---- the fleet path: the REAL agent loop answers ----
  // One tab-lifetime thread in the real session capsule; react echoes it in
  // every event, so the pill filters on it.
  const FLEET_SESSION = 'web-tab';
  let fleetWired = false;
  let fleetTurn: Turn | null = null;

  function wireFleetEvents(b: AstridBridge): void {
    if (fleetWired) return;
    fleetWired = true;
    // Deltas and the terminal reply both arrive as real bus events published
    // by the react capsule; the pill is just another uplink rendering them.
    b.subscribe('agent.v1.stream.delta', (_t, json) => {
      if (!fleetTurn) return;
      try {
        const p = JSON.parse(json) as { text?: string; session_id?: string };
        if (p.session_id !== FLEET_SESSION || !p.text) return;
        fleetTurn.text = fleetTurn.text === '…' ? p.text : fleetTurn.text + p.text;
        updateStream(fleetTurn.text);
        linkSend?.({ t: 'partial', text: fleetTurn.text });
      } catch {
        /* delta parse is best-effort; the terminal reply is authoritative */
      }
    });
    // The generation itself streams here: the openai-compat capsule only
    // sees the completion once it's whole, so the model publishes its
    // running text while it works. Cumulative text — replace, not append.
    b.subscribe('site.agent.v1.partial', (_t, json) => {
      if (!fleetTurn) return;
      try {
        const p = JSON.parse(json) as { text?: string };
        if (!p.text) return;
        fleetTurn.text = p.text;
        updateStream(p.text);
        linkSend?.({ t: 'partial', text: p.text });
      } catch {
        /* partials are best-effort; the terminal reply is authoritative */
      }
    });
    b.subscribe('agent.v1.response', (_t, json) => {
      if (!fleetTurn) return;
      try {
        const p = JSON.parse(json) as { text?: string; is_final?: boolean; session_id?: string };
        if (p.session_id !== FLEET_SESSION || !p.is_final) return;
        fleetTurn.text = p.text ?? fleetTurn.text;
        const done = fleetTurn.text;
        fleetTurn = null;
        renderTranscript();
        finishTurn(done);
      } catch {
        /* keep whatever the deltas built */
      }
    });
  }

  // Streaming text rolls into the last answer in place, character by
  // character, instead of re-snapping the whole transcript on every delta.
  let streamEl: HTMLElement | null = null;
  let streamShown = '';

  function rollIn(el: HTMLElement, delta: string): void {
    const frag = document.createDocumentFragment();
    let i = 0;
    for (const ch of delta) {
      const s = document.createElement('span');
      s.className = 'roll';
      s.textContent = ch;
      s.style.animationDelay = `${Math.min(i++, 24) * 12}ms`;
      frag.append(s);
    }
    el.append(frag);
  }

  // Follow the stream only while the reader is at the bottom; scrolling up
  // to reread must not be fought.
  function atBottom(): boolean {
    return panel.scrollHeight - panel.scrollTop - panel.clientHeight < 64;
  }

  function updateStream(text: string): void {
    if (!streamEl?.isConnected) {
      renderTranscript();
      return;
    }
    const stick = atBottom();
    if (text.startsWith(streamShown)) {
      rollIn(streamEl, text.slice(streamShown.length));
    } else {
      streamEl.textContent = '';
      rollIn(streamEl, text);
    }
    streamShown = text;
    if (stick) panel.scrollTop = panel.scrollHeight;
  }

  function renderTranscript(force = false): void {
    const stick = force || atBottom();
    results.innerHTML = '';
    streamEl = null;
    for (const t of transcript) {
      const p = document.createElement('p');
      p.className = t.role === 'user' ? 'turn-you mono' : 'answer';
      p.textContent = t.role === 'user' ? `You · ${t.text}` : t.text;
      results.append(p);
      if (t.role === 'assistant') {
        streamEl = p;
        streamShown = t.text;
      }
      if (t.refs?.length) {
        const ctx = document.createElement('p');
        ctx.className = 'ctx mono';
        ctx.append('Grounded in: ');
        t.refs.forEach((r, i) => {
          if (i > 0) ctx.append(' · ');
          const a = document.createElement('a');
          a.className = 'ref';
          a.href = `/developers/${r.slug}/`;
          a.textContent = r.title;
          ctx.append(a);
        });
        results.append(ctx);
      }
    }
    if (stick) panel.scrollTop = panel.scrollHeight;
  }

  // One ask path for every entrance — typed, spoken, or arriving from the
  // phone uplink. finishTurn is the single exit: it forwards the final text
  // to a linked phone and speaks it when the question came in by voice.
  async function runAsk(q: string): Promise<void> {
    // Preferred path: the real fleet. user.v1.prompt goes to the real
    // react capsule, session records the thread, prompt-builder
    // assembles, openai-compat parses the local model's completion.
    if (agentState() === 'ready' && bridge && fleetReady()) {
      wireFleetEvents(bridge);
      transcript.push({ role: 'user', text: q });
      fleetTurn = { role: 'assistant', text: '…' };
      transcript.push(fleetTurn);
      renderTranscript(true);
      // fleetAsk retrieves developer-guide grounding first (it rides in the system
      // prompt), then publishes the turn; the refs it returns are the
      // chapters the answer is grounded in. Capture the turn locally:
      // fleetTurn is nulled once the final response lands.
      const turn = fleetTurn;
      const chapters = await fleetAsk(FLEET_SESSION, q);
      if (chapters.length) {
        turn.refs = chapters.map((c) => ({ slug: c.slug, title: c.title }));
        renderTranscript();
      }
      return; // the final lands in the agent.v1.response subscription
    }
    const chapters = await searchGuide(q, 3);
    if (agentState() === 'ready' && bridge) {
      const history = transcript.map((t) => ({
        role: t.role,
        content: t.text,
      }));
      transcript.push({ role: 'user', text: q });
      const reply: Turn = {
        role: 'assistant',
        text: '…',
        refs: chapters.map((c) => ({ slug: c.slug, title: c.title })),
      };
      transcript.push(reply);
      renderTranscript(true);
      try {
        // The return value matters: mid-stream the strict think-strip can
        // leave the bubble empty, and the final text salvages that case.
        const answer = await askAgent(bridge, q, chapters, history, (full) => {
          if (full) {
            reply.text = full;
            updateStream(full);
            linkSend?.({ t: 'partial', text: full });
          }
        });
        reply.text = answer || '(The model returned nothing. Ask again?)';
        renderTranscript();
        finishTurn(reply.text);
      } catch (err) {
        reply.text = `Agent failed: ${err instanceof Error ? err.message : err}`;
        renderTranscript();
        finishTurn(reply.text);
      }
    } else {
      renderChapters(chapters, `Chapters matching "${q}":`);
    }
  }

  $('pill-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const q = input.value.trim();
    if (!q) return;
    voiceTurn = false; // typed questions get silent answers
    input.value = '';
    showPanel();
    void runAsk(q);
  });

  function finishTurn(text: string): void {
    linkBusy = false;
    linkSend?.({ t: 'final', text });
    speakIfVoice(text);
  }

  // ---- voice in (SpeechRecognition) / voice out (speechSynthesis) ----
  // Shown only where the browser can actually hear; the answer is spoken
  // only when the question was.
  const srGlobal = window as unknown as { SpeechRecognition?: unknown; webkitSpeechRecognition?: unknown };
  const SRCtor = (srGlobal.SpeechRecognition ?? srGlobal.webkitSpeechRecognition) as
    | (new () => {
        lang: string;
        interimResults: boolean;
        onresult: ((e: { results: { length: number; [i: number]: { isFinal: boolean; 0?: { transcript: string } } } }) => void) | null;
        onend: (() => void) | null;
        start(): void;
        stop(): void;
        abort(): void;
      })
    | undefined;
  const micBtn = $('pill-mic') as HTMLButtonElement;
  let rec: { stop(): void; abort(): void } | null = null;
  let voiceTurn = false;
  if (SRCtor) micBtn.hidden = false;

  function speakIfVoice(text: string): void {
    if (!voiceTurn) return;
    voiceTurn = false;
    if (!('speechSynthesis' in window) || !text) return;
    speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.lang = navigator.language || 'en';
    speechSynthesis.speak(u);
  }

  micBtn.addEventListener('click', () => {
    if (!SRCtor) return;
    if (rec) {
      rec.abort();
      return;
    }
    const r = new SRCtor();
    rec = r;
    const prevPlaceholder = input.placeholder;
    r.lang = navigator.language || 'en';
    r.interimResults = true;
    micBtn.dataset.on = 'true';
    input.placeholder = 'Listening…';
    r.onresult = (e) => {
      let text = '';
      let final = false;
      for (let i = 0; i < e.results.length; i++) {
        text += e.results[i][0]?.transcript ?? '';
        if (e.results[i].isFinal) final = true;
      }
      input.value = text.trim();
      if (final && input.value) {
        const q = input.value;
        input.value = '';
        voiceTurn = true;
        r.stop();
        showPanel();
        void runAsk(q);
      }
    };
    r.onend = () => {
      rec = null;
      delete micBtn.dataset.on;
      input.placeholder = prevPlaceholder;
    };
    r.start();
  });

  // ---- the phone uplink: QR → encrypted signaling → WebRTC → this bus ----
  // The phone is a dumb terminal. This side enforces that: exactly one verb
  // (ask), length-capped, one in flight, behind a real granted-and-checked
  // capability, with the ask mirrored onto the bus attributed to the uplink
  // so the rail and the receipt see it.
  let linkSend: ((m: unknown) => void) | null = null;
  let linkHandle: { send(m: unknown): void; close(): void } | null = null;
  let linkGranted = false;
  let linkBusy = false;

  const phoneBtn = $('pill-phone') as HTMLButtonElement;
  const linkOpen = $('pill-link-open');
  const linkStatusEl = $('pill-link-status');

  async function onPhoneAsk(m: Record<string, unknown>): Promise<void> {
    if (m.t !== 'ask' || typeof m.text !== 'string') return; // one verb, exactly
    const text = m.text.trim().slice(0, 300);
    if (!text) return;
    if (linkBusy) {
      linkSend?.({ t: 'status', text: 'One question at a time; the last one is still running.' });
      return;
    }
    if (!bridge || agentState() !== 'ready') {
      linkSend?.({ t: 'status', text: 'No model is enabled on the desktop yet. Click "Enable AI" there first.' });
      return;
    }
    if (!linkGranted) {
      await bridge.grant('uplink-phone', 'topic:user.v1.prompt', 'write');
      linkGranted = true;
    }
    const ok = await bridge.check('uplink-phone', 'topic:user.v1.prompt', 'write');
    if (!ok) {
      linkSend?.({ t: 'status', text: 'The uplink’s permission was revoked on the desktop.' });
      return;
    }
    bridge.hostPublish?.('uplink-phone', 'site.v1.uplink.ask', JSON.stringify({ chars: text.length }));
    linkSend?.({ t: 'you', text });
    linkBusy = true;
    showPanel();
    try {
      await runAsk(text);
    } catch {
      linkBusy = false;
    }
  }

  async function togglePhoneLink(): Promise<void> {
    if (linkHandle) {
      linkHandle.close();
      linkHandle = null;
      linkSend = null;
      linkOpen.hidden = true;
      phoneBtn.textContent = 'Use your phone →';
      return;
    }
    phoneBtn.textContent = '✕ Stop the phone link';
    linkOpen.hidden = false;
    linkStatusEl.textContent = 'Setting up…';
    const canvas = $('pill-qr') as HTMLCanvasElement;
    canvas.hidden = false;
    try {
      const [link, QR] = await Promise.all([import('../scripts/phone-link'), import('qrcode')]);
      const secret = link.mintSecret();
      await QR.toCanvas(canvas, `${location.origin}/link/#${secret}`, {
        width: 164,
        margin: 0,
        color: { dark: '#07080d', light: '#ffffff' },
      });
      linkStatusEl.textContent =
        'Scan with your phone camera. The code carries a one-time secret; once linked, your phone talks to this tab directly.';
      linkHandle = await link.hostLink(secret, {
        onStatus: (s, detail) => {
          if (s === 'connected') {
            canvas.hidden = true;
            linkStatusEl.dataset.ok = '1';
            linkStatusEl.textContent = '✓ Phone linked';
          } else if (s === 'failed') {
            delete linkStatusEl.dataset.ok;
            linkStatusEl.textContent = `The link failed: ${detail ?? 'the connection never formed'}.`;
          } else if (s === 'closed') {
            delete linkStatusEl.dataset.ok;
            canvas.hidden = false;
            linkStatusEl.textContent = 'Phone disconnected. The code still works to reconnect.';
          }
        },
        onMessage: (m) => void onPhoneAsk(m),
      });
      linkSend = (msg) => linkHandle?.send(msg);
    } catch (err) {
      linkStatusEl.textContent = `Couldn't set up the link: ${err instanceof Error ? err.message : err}`;
    }
  }

  phoneBtn.addEventListener('click', () => void togglePhoneLink());

  // Click-away closes the panel.
  document.addEventListener('click', (e) => {
    if (!wrap.contains(e.target as Node)) panel.hidden = true;
  });
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape' || panel.hidden) return;
    panel.hidden = true;
    input.focus();
  });
</script>
