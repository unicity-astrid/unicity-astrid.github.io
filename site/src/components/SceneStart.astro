---
/** Section 8 — get started + footer. */
import unicityMark from '../assets/unicity-wordmark.svg?raw';
---

<section class="start hairline-top" id="start">
  <div class="wrap start-grid">
    <div class="prose">
      <h2 class="start-title">Run it.</h2>
      <p class="dim">
        One daemon. Every frontend is an uplink; every ability is a capsule.
      </p>
      <pre class="card start-term"><code><span class="dim">$</span> brew install unicity-astrid/tap/astrid
<span class="dim">$</span> astrid start</code></pre>
    </div>
    <nav class="start-links mono" aria-label="Project links">
      <a href="/start/">start building →</a>
      <a href="https://github.com/unicity-astrid/astrid">github.com/unicity-astrid</a>
      <a href="https://github.com/unicity-astrid/rfcs">the RFCs</a>
      <a href="https://github.com/unicity-astrid/sdk-rust">capsule SDK (Rust)</a>
      <a href="/book/">the book</a>
    </nav>
  </div>
  <footer class="footer">
    <div class="wrap footer-inner">
      <p class="mono dim footer-tag">
        Run AI agents and the tools they use without having to trust them.
      </p>
      <p class="mono footer-fine" id="footer-live">ASTRID</p>
    </div>
    <div class="wrap footer-made">
      <a
        class="footer-unicity"
        href="https://www.unicity.ai/"
        aria-label="Unicity"
        set:html={unicityMark}
      />
      <p class="mono footer-fine">
        Astrid is made by <a href="https://www.unicity.ai/">Unicity</a> · © 2026 Unicity
      </p>
    </div>
  </footer>
</section>

<style>
  .start {
    padding-top: var(--s-8);
  }

  .start-grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: var(--s-6);
    align-items: end;
    padding-bottom: var(--s-7);
  }

  @media (max-width: 900px) {
    .start-grid {
      grid-template-columns: 1fr;
    }
  }

  .start-title {
    font-size: var(--step-5);
    margin-bottom: var(--s-2);
  }

  .start-term {
    margin-top: var(--s-3);
    padding: var(--s-3);
    font-size: var(--step-0);
    line-height: 1.9;
    overflow-x: auto;
  }

  .start-links {
    display: grid;
    gap: var(--s-1);
    font-size: var(--step--1);
    justify-items: start;
  }

  .footer {
    border-top: 1px solid var(--line);
    padding-block: var(--s-4);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .footer-tag {
    font-size: var(--step--1);
  }

  .footer-fine {
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    color: var(--text-faint);
  }

  .footer-made {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-top: var(--s-4);
    padding-top: var(--s-3);
    border-top: 1px solid var(--line);
  }

  .footer-made .footer-fine {
    letter-spacing: 0.12em;
  }

  .footer-made .footer-fine a {
    color: var(--text-dim);
  }

  .footer-made .footer-fine a:hover {
    color: var(--text);
  }

  .footer-unicity {
    color: var(--text-faint);
    display: inline-flex;
    transition: color var(--t-fast, 0.15s) ease;
  }

  .footer-unicity:hover {
    color: var(--text);
  }

  .footer-unicity :global(svg) {
    height: 20px;
    width: auto;
  }
</style>

<script>
  import { onKernel, kernel } from '../scripts/kernel';

  // the footer wordmark quietly counts real routed events; a signature, not a
  // widget. One module-lifetime interval, re-finding its element every tick,
  // so navigations neither stack timers nor strand a stale node.
  let ticking = false;
  onKernel((status) => {
    if (status !== 'online' || ticking) return;
    ticking = true;
    setInterval(() => {
      const el = document.getElementById('footer-live');
      const bridge = kernel();
      if (el && bridge) el.textContent = `ASTRID · ${bridge.eventsRouted()} EVENTS ROUTED IN YOUR TAB`;
    }, 2000);
  });
</script>
