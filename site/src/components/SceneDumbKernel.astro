---
/** Section 2 — "The kernel is dumb. That is the point."
 *  The rail routes between endpoints that clamp on from the edges; a live
 *  demo publisher fires real publishes while the section is on screen, and
 *  every pulse on the rail is a real EventBus delivery. */
---

<section class="scene wrap" id="dumb-kernel" data-scene>
  <div class="scene-copy prose">
    <p class="eyebrow">01 · the engine</p>
    <h2>One small engine.<br />No opinions.</h2>
    <p>
      At the core of Astrid sits a deliberately tiny engine. It carries
      messages, checks permissions, and keeps records. Nothing else. It holds
      no AI and makes no decisions, which is exactly why everything built on
      top of it is safe to swap, and why no single company's model gets to be
      the landlord.
    </p>
    <p>
      That thin line on the left is the whole engine. Everything else on this
      page clamps onto it.
    </p>
    <canvas class="dk-ekg" id="dk-ekg" height="56" aria-hidden="true"></canvas>
    <p class="mono live-caption" id="dk-caption" hidden>
      This part's heartbeat · every beat is a real message it just routed ·
      <span id="dk-count">0</span> so far
    </p>
    <p class="mono live-caption off-caption" id="dk-off" hidden>
      Flatline. The part is out of the engine, its permission revoked.
    </p>
    <button class="dk-kill mono" id="dk-kill" hidden data-armed="true">
      ✕ disable the part that powers this section
    </button>
  </div>
  <div class="endpoints" aria-hidden="true">
    <span class="dock-chip" data-dock="uplink">your terminal</span>
    <span class="dock-chip" data-dock="uplink">your browser</span>
    <span class="dock-chip" data-dock="uplink">your Discord</span>
  </div>
</section>

<style>
  .scene {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
    gap: var(--s-5);
    align-items: center;
    padding-block: var(--s-8);
  }

  @media (max-width: 900px) {
    .scene {
      grid-template-columns: 1fr;
    }
  }

  .scene-copy h2 {
    font-size: var(--step-4);
    margin-block: var(--s-2) var(--s-3);
  }

  .scene-copy p + p {
    margin-top: var(--s-2);
  }

  .endpoints {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s-4);
  }

  /* Phones: the chips lose their own column and stack under the copy — as
     a sparse tower they read as stray buttons. A tight wrapping row reads
     as what they are: a set of plugs on the same bus. */
  @media (max-width: 640px) {
    .endpoints {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--s-2);
    }
  }

  /* the heartbeat monitor: beats are real routed messages; disabling the
     part flatlines it — no words needed */
  .dk-ekg {
    display: block;
    width: 100%;
    max-width: 30rem;
    height: 56px;
    margin-top: var(--s-3);
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg-raised);
  }

  @media (prefers-reduced-motion: reduce) {
    .dk-ekg {
      display: none;
    }
  }

  .live-caption {
    font-size: var(--step--1);
    color: var(--bus);
  }

  .live-caption span {
    font-variant-numeric: tabular-nums;
  }

  .off-caption {
    color: var(--deny);
  }

  /* the dare: a real uninstall button, in daylight instead of a drawer */
  .dk-kill {
    margin-top: var(--s-3);
    justify-self: start;
    background: none;
    border: 1px solid color-mix(in srgb, var(--deny) 45%, transparent);
    border-radius: 999px;
    color: var(--deny);
    font-size: var(--step--1);
    padding: 0.55em 1.2em;
    cursor: pointer;
    transition: border-color var(--t-fast) var(--ease-out), color var(--t-fast) var(--ease-out);
  }

  .dk-kill:hover {
    border-color: var(--deny);
  }

  .dk-kill[data-armed='false'] {
    border-color: color-mix(in srgb, var(--grant) 45%, transparent);
    color: var(--grant);
  }

  .dk-kill[data-armed='false']:hover {
    border-color: var(--grant);
  }

  /* the honest consequence: the section visibly dies with its capsule */
  .scene[data-dead='true'] .endpoints {
    opacity: 0.25;
    transition: opacity var(--t-med) var(--ease-out);
  }
</style>

<script>
  import { onKernel, kernel, kernelStatus } from '../scripts/kernel';
  import { capsuleState, onSectionCapsules, toggleCapsule } from '../scripts/section-capsules';

  // Module state survives client-router navigations; elements do not. All
  // DOM refs are looked up at use time, and wire() re-arms per page visit.
  let seen = 0;
  let n = 0;
  let timer: number | undefined;
  let io: IntersectionObserver | null = null;
  let subscribed = false;

  function applyState(): void {
    const caption = document.getElementById('dk-caption');
    const offNote = document.getElementById('dk-off');
    const count = document.getElementById('dk-count');
    const kill = document.getElementById('dk-kill') as HTMLButtonElement | null;
    const section = document.getElementById('dumb-kernel');
    const state = capsuleState('site-pulse');
    const dead = state === 'uninstalled';
    if (caption) caption.hidden = kernelStatus() !== 'online' || dead;
    // Only flag the uninstalled state when the capsule system is actually
    // present in this build; 'unavailable' keeps the old caption honest.
    if (offNote) offNote.hidden = !dead;
    if (count) count.textContent = String(seen);
    if (section) section.dataset.dead = String(dead);
    if (kill) {
      // the dare only appears when the disable would be REAL
      kill.hidden = state === 'unavailable' || state === 'error';
      kill.dataset.armed = String(!dead);
      kill.textContent = dead
        ? '↺ Re-enable it, and the section comes back to life'
        : '✕ disable the part that powers this section';
    }
  }

  // ---- the heartbeat monitor ----
  // A scrolling EKG trace: every REAL routed message injects a beat; when
  // the part is disabled no beats arrive and the line flatlines. The trace
  // itself is the explanation — no prose required. One module-lifetime
  // loop; it draws only while the canvas exists and is on screen.
  let spike = 0;
  const trace: number[] = [];
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function beat(): void {
    spike = 1;
  }

  function drawEkg(): void {
    const c = document.getElementById('dk-ekg') as HTMLCanvasElement | null;
    if (!c) return;
    const dpr = Math.min(devicePixelRatio || 1, 2);
    const w = Math.max(1, Math.round(c.clientWidth * dpr));
    const h = Math.max(1, Math.round(c.clientHeight * dpr));
    if (c.width !== w) c.width = w;
    if (c.height !== h) c.height = h;
    const ctx = c.getContext('2d');
    if (!ctx) return;

    const dead = capsuleState('site-pulse') === 'uninstalled';
    const online = kernelStatus() === 'online';
    // one sample per frame: baseline + a decaying spike on each real beat
    spike *= 0.82;
    const base = h * 0.6;
    const jitter = dead || !online ? 0 : (Math.random() - 0.5) * h * 0.03;
    trace.push(base - spike * h * 0.4 + jitter);
    const step = 2 * dpr;
    const maxSamples = Math.ceil(w / step) + 1;
    while (trace.length > maxSamples) trace.shift();

    const css = getComputedStyle(c);
    ctx.clearRect(0, 0, w, h);
    ctx.lineWidth = 1.5 * dpr;
    ctx.strokeStyle = dead
      ? css.getPropertyValue('--deny').trim() || '#f87171'
      : css.getPropertyValue('--bus').trim() || '#5eead4';
    ctx.globalAlpha = online ? 0.9 : 0.35;
    ctx.beginPath();
    for (let i = 0; i < trace.length; i++) {
      const x = w - (trace.length - 1 - i) * step;
      if (i === 0) ctx.moveTo(x, trace[i]);
      else ctx.lineTo(x, trace[i]);
    }
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  if (!reduced) {
    const ekgLoop = () => {
      drawEkg();
      requestAnimationFrame(ekgLoop);
    };
    requestAnimationFrame(ekgLoop);
  }

  // The page is the clock (a sandboxed guest has no timer authority): real
  // tick publishes while the scene is visible. The ROUTING lives in the
  // site-pulse capsule; the counter only moves when site-pulse turns a tick
  // into site.v1.demo.route. Uninstall it and this element goes quiet.
  function wire(): void {
    if (timer !== undefined) {
      clearInterval(timer);
      timer = undefined;
    }
    io?.disconnect();
    io = null;
    const section = document.getElementById('dumb-kernel');
    if (!section) return;
    io = new IntersectionObserver((entries) => {
      const on = entries[0]?.isIntersecting ?? false;
      if (on && timer === undefined) {
        timer = window.setInterval(() => {
          const bridge = kernel();
          if (!bridge) return;
          // Builds without the capsule assets fall back to routing directly
          // (still a real publish); with site-pulse present, the capsule
          // owns the routing. While the part is DISABLED the page goes
          // quiet on purpose: publishing ticks nobody routes would keep the
          // rail pulsing and hide the consequence.
          const state = capsuleState('site-pulse');
          if (state === 'unavailable') {
            void bridge.publish(
              'site.v1.demo.route',
              JSON.stringify({ scene: 'dumb-kernel', via: 'page' }),
            );
          } else if (state === 'installed') {
            void bridge.publish('site.v1.clock.tick', JSON.stringify({ n: ++n }));
          }
        }, 2600);
      } else if (!on && timer !== undefined) {
        clearInterval(timer);
        timer = undefined;
      }
    });
    io.observe(section);
    const kill = document.getElementById('dk-kill');
    kill?.addEventListener('click', () => void toggleCapsule('site-pulse'));
    applyState();
  }

  onKernel((status, bridge) => {
    if (status === 'online' && bridge && !subscribed) {
      subscribed = true;
      bridge.subscribe('site.v1.demo.*', () => {
        seen += 1;
        beat();
        const count = document.getElementById('dk-count');
        if (count) count.textContent = String(seen);
      });
    }
    applyState();
  });
  onSectionCapsules(applyState);
  document.addEventListener('astro:page-load', wire);
</script>
